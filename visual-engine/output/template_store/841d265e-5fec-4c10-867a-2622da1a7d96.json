      "html": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Design Conversion</title>\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&display=swap\" rel=\"stylesheet\">\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&display=swap');\n\n        :root {\n            --bg: #F5F4F0;\n            --primary: #4CAF80; /* Main accent color, used for green elements */\n            --secondary: #D9D9D9; /* Grey for cards */\n            --accent: #4CAF80; /* Highlight color for text */\n            --text: #222222;\n            --text-muted: #888888;\n            --surface: #FFFFFF; /* General surface color, though cards use specific colors */\n            --card-grey: #D9D9D9;\n            --card-black: #222222;\n            --card-green: #4CAF80;\n            --decorative-lines: #EAEAEA;\n        }\n\n        body {\n            margin: 0;\n            padding: 0;\n            width: 1080px;\n            height: 1080px;\n            overflow: hidden;\n            background: var(--bg);\n            font-family: 'Inter', sans-serif;\n            color: var(--text);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .slide {\n            width: 1080px;\n            height: 1080px;\n            padding: 60px 72px;\n            box-sizing: border-box;\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between; /* Pushes content to center and footer to bottom */\n            position: relative;\n            align-items: flex-start; /* Align content to the left */\n        }\n\n        .content-area {\n            margin-top: auto; /* Push content block to center vertically */\n            margin-bottom: auto; /* Push content block to center vertically */\n            display: flex;\n            flex-direction: column;\n            align-items: flex-start;\n            gap: 10px; /* Default gap between text elements */\n        }\n\n        .main-headline {\n            font-size: 80px;\n            font-weight: 800;\n            line-height: 1.1;\n            margin: 0;\n            padding: 0;\n        }\n\n        .large-number {\n            font-size: 120px;\n            font-weight: 800;\n            line-height: 1;\n            margin: 20px 0 0 0; /* Space from headline */\n            padding: 0;\n            position: relative;\n        }\n\n        .large-number::before {\n            content: '';\n            position: absolute;\n            bottom: 15px; /* Adjust based on font baseline */\n            left: 0;\n            width: 100px; /* Length of the underline */\n            height: 4px;\n            background-color: var(--accent);\n            border-radius: 2px;\n        }\n\n        .supporting-text {\n            font-size: 20px;\n            font-weight: 400;\n            color: var(--text-muted);\n            margin: 10px 0 0 0; /* Space from large number */\n            padding: 0;\n        }\n\n        .highlight {\n            color: var(--accent);\n            font-style: italic;\n        }\n\n        .card-container {\n            display: flex;\n            gap: 24px;\n            margin-top: 80px; /* Space from text block */\n            z-index: 10; /* Ensure cards are above decorative elements */\n        }\n\n        .card {\n            width: 120px;\n            height: 120px;\n            border-radius: 16px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            transform: perspective(500px) rotateX(2deg);\n            transition: transform 0.2s ease-out, box-shadow 0.2s ease-out;\n        }\n\n        .card-grey {\n            background: var(--card-grey);\n            box-shadow: 0 4px 0 rgba(0,0,0,0.08), 0 8px 20px rgba(0,0,0,0.05);\n        }\n\n        .card-black {\n            background: var(--card-black);\n            box-shadow: 0 4px 0 rgba(0,0,0,0.15), 0 8px 20px rgba(0,0,0,0.1);\n        }\n\n        .card-green {\n            background: var(--card-green);\n            box-shadow: 0 4px 0 rgba(0,0,0,0.15), 0 8px 20px rgba(0,0,0,0.1);\n        }\n\n        .card-icon {\n            width: 48px;\n            height: 48px;\n            margin-bottom: 8px;\n        }\n\n        .card-grey .card-icon {\n            color: var(--text);\n        }\n\n        .card-black .card-icon,\n        .card-green .card-icon {\n            color: white;\n        }\n\n        .card-label {\n            font-size: 12px;\n            font-weight: 500;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n            color: inherit; /* Inherit color from icon for consistency */\n        }\n        .card-grey .card-label {\n            color: var(--text);\n        }\n        .card-black .card-label,\n        .card-green .card-label {\n            color: white;\n        }\n\n\n        .footer {\n            position: absolute;\n            bottom: 40px;\n            left: 72px;\n            right: 72px;\n            display: flex;\n            justify-content: space-between;\n            font-size: 13px;\n            color: var(--text-muted);\n            line-height: 1.4;\n        }\n\n        .footer-right {\n            display: flex;\n            align-items: center;\n            gap: 5px;\n        }\n        .footer-right .lucide {\n            width: 1em;\n            height: 1em;\n            stroke-width: 2.5;\n        }\n\n        /* Decorative background pattern */\n        .decorative-pattern {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            overflow: hidden;\n            z-index: 0;\n        }\n\n        .deco-element {\n            position: absolute;\n            background-color: var(--decorative-lines);\n            opacity: 0.6;\n        }\n\n        /* Top-right pattern */\n        .deco-element.dot-tr-1 { width: 6px; height: 6px; border-radius: 50%; top: 100px; right: 150px; }\n        .deco-element.line-tr-1 { width: 80px; height: 2px; transform: rotate(45deg); top: 100px; right: 150px; transform-origin: top left; }\n        .deco-element.dot-tr-2 { width: 6px; height: 6px; border-radius: 50%; top: 150px; right: 100px; }\n        .deco-element.line-tr-2 { width: 60px; height: 2px; transform: rotate(-30deg); top: 150px; right: 100px; transform-origin: top right; }\n        .deco-element.dot-tr-3 { width: 6px; height: 6px; border-radius: 50%; top: 180px; right: 160px; }\n        .deco-element.line-tr-3 { width: 40px; height: 2px; transform: rotate(70deg); top: 150px; right: 100px; transform-origin: top left; }\n\n        /* Mid-right pattern */\n        .deco-element.dot-mr-1 { width: 6px; height: 6px; border-radius: 50%; top: 400px; right: 80px; }\n        .deco-element.line-mr-1 { width: 50px; height: 2px; transform: rotate(10deg); top: 400px; right: 80px; transform-origin: top right; }\n        .deco-element.dot-mr-2 { width: 6px; height: 6px; border-radius: 50%; top: 420px; right: 30px; }\n\n        /* Bottom-left pattern */\n        .deco-element.dot-bl-1 { width: 6px; height: 6px; border-radius: 50%; bottom: 150px; left: 100px; }\n        .deco-element.line-bl-1 { width: 70px; height: 2px; transform: rotate(-45deg); bottom: 150px; left: 100px; transform-origin: bottom left; }\n        .deco-element.dot-bl-2 { width: 6px; height: 6px; border-radius: 50%; bottom: 100px; left: 150px; }\n        .deco-element.line-bl-2 { width: 40px; height: 2px; transform: rotate(20deg); bottom: 100px; left: 150px; transform-origin: bottom right; }\n        .deco-element.dot-bl-3 { width: 6px; height: 6px; border-radius: 50%; bottom: 80px; left: 190px; }\n\n        /* Bottom-right pattern */\n        .deco-element.dot-br-1 { width: 6px; height: 6px; border-radius: 50%; bottom: 180px; right: 120px; }\n        .deco-element.line-br-1 { width: 60px; height: 2px; transform: rotate(30deg); bottom: 180px; right: 120px; transform-origin: bottom right; }\n        .deco-element.dot-br-2 { width: 6px; height: 6px; border-radius: 50%; bottom: 150px; right: 70px; }\n\n    </style>\n</head>\n<body>\n    <div class=\"slide\">\n        <div class=\"decorative-pattern\">\n            <!-- Top-right pattern -->\n            <div class=\"deco-element dot-tr-1\"></div>\n            <div class=\"deco-element line-tr-1\"></div>\n            <div class=\"deco-element dot-tr-2\"></div>\n            <div class=\"deco-element line-tr-2\"></div>\n            <div class=\"deco-element dot-tr-3\"></div>\n            <div class=\"deco-element line-tr-3\"></div>\n\n            <!-- Mid-right pattern -->\n            <div class=\"deco-element dot-mr-1\"></div>\n            <div class=\"deco-element line-mr-1\"></div>\n            <div class=\"deco-element dot-mr-2\"></div>\n\n            <!-- Bottom-left pattern -->\n            <div class=\"deco-element dot-bl-1\"></div>\n            <div class=\"deco-element line-bl-1\"></div>\n            <div class=\"deco-element dot-bl-2\"></div>\n            <div class=\"deco-element line-bl-2\"></div>\n            <div class=\"deco-element dot-bl-3\"></div>\n\n            <!-- Bottom-right pattern -->\n            <div class=\"deco-element dot-br-1\"></div>\n            <div class=\"deco-element line-br-1\"></div>\n            <div class=\"deco-element dot-br-2\"></div>\n        </div>\n\n        <div class=\"content-area\">\n            <h1 class=\"main-headline\">{{headline}}</h1>\n            <p class=\"large-number\">{{slide_number}}</p>\n            <p class=\"supporting-text\">{{body}}</p>\n\n            <div class=\"card-container\">\n                <div class=\"card card-grey\">\n                    <i data-lucide=\"mail\" class=\"card-icon\"></i>\n                    <span class=\"card-label\">EMAIL</span>\n                </div>\n                <div class=\"card card-black\">\n                    <i data-lucide=\"bot\" class=\"card-icon\"></i>\n                    <span class=\"card-label\">AGENT</span>\n                </div>\n                <div class=\"card card-green\">\n                    <i data-lucide=\"calendar\" class=\"card-icon\"></i>\n                    <span class=\"card-label\">SCHEDULE</span>\n                </div>\n                <div class=\"card card-grey\">\n                    <i data-lucide=\"code\" class=\"card-icon\"></i>\n                    <span class=\"card-label\">CODE</span>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"footer\">\n            <div class=\"footer-left\">Instagram<br>{{brand_name}}</div>\n            <div class=\"footer-right\">\n                {{cta_text}} <i data-lucide=\"arrow-right\"></i>\n            </div>\n        </div>\n    </div>\n    <script>lucide.createIcons()</script>\n</body>\n</html>",
      "colors": {
        "bg": "#F5F4F0",
        "primary": "#4CAF80",
