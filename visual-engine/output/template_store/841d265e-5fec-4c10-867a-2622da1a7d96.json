    {
      "name": "dark-modern",
      "description": "AI-extracted template from reference design",
      "html": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Design Conversion</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap\" rel=\"stylesheet\">\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <style>\n        /* CSS Variables */\n        :root {\n            --bg: #1A1A1A;\n            --primary: #50E3C2; /* Teal for subheadline, left card */\n            --secondary: #9B51E0; /* Purple for middle card */\n            --accent-green: #A0FF00; /* Lime Green for right card */\n            --text: #E0E0E0;\n            --text-muted: #A0A0A0;\n            --surface: #2A2A2A;\n            --headline-highlight: #A0A0A0; /* For \"entire\" in headline */\n        }\n\n        /* Base Styles */\n        body {\n            margin: 0; padding: 0;\n            width: 1080px; height: 1080px;\n            overflow: hidden;\n            background: var(--bg);\n            font-family: 'Inter', sans-serif;\n            color: var(--text);\n            position: relative;\n        }\n\n        /* Background Pattern */\n        body::before {\n            content: '';\n            position: absolute;\n            top: 0; left: 0; right: 0; bottom: 0;\n            background-image:\n                radial-gradient(circle at 10% 20%, rgba(255,255,255,0.02) 1px, transparent 1px),\n                radial-gradient(circle at 90% 80%, rgba(255,255,255,0.02) 1px, transparent 1px),\n                radial-gradient(circle at 50% 50%, rgba(255,255,255,0.02) 1px, transparent 1px),\n                radial-gradient(circle at 30% 70%, rgba(255,255,255,0.02) 1px, transparent 1px),\n                radial-gradient(circle at 70% 30%, rgba(255,255,255,0.02) 1px, transparent 1px);\n            background-size: 60px 60px; /* Adjust for desired density */\n            opacity: 0.8;\n            z-index: 0;\n        }\n\n        .slide {\n            width: 1080px; height: 1080px;\n            padding: 60px 72px;\n            box-sizing: border-box;\n            display: flex; flex-direction: column;\n            justify-content: center;\n            position: relative;\n            z-index: 1; /* Ensure content is above background pattern */\n        }\n\n        /* Typography */\n        .subheadline {\n            font-size: 14px;\n            font-weight: 600;\n            color: var(--primary);\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            margin-bottom: 16px;\n        }\n\n        .headline {\n            font-size: 72px;\n            font-weight: 700;\n            line-height: 1.1;\n            margin-bottom: 24px;\n        }\n\n        .headline .highlight {\n            color: var(--headline-highlight);\n            font-style: normal;\n        }\n\n        .body-text {\n            font-size: 20px;\n            font-weight: 400;\n            color: var(--text-muted);\n            line-height: 1.5;\n            max-width: 600px;\n            margin-bottom: 80px;\n        }\n\n        /* Cards Section */\n        .cards-container {\n            display: flex;\n            gap: 24px;\n            margin-top: auto; /* Push cards to bottom */\n        }\n\n        .card {\n            background: var(--surface);\n            border-radius: 16px;\n            padding: 32px;\n            width: calc((100% - 48px) / 3); /* 3 cards, 2 gaps of 24px */\n            box-sizing: border-box;\n            display: flex;\n            flex-direction: column;\n            position: relative;\n        }\n\n        .card::before {\n            content: '';\n            position: absolute;\n            top: 0; left: 0; right: 0; bottom: 0;\n            border-radius: 16px;\n            border: 1px solid transparent;\n            pointer-events: none;\n            z-index: 2;\n        }\n\n        .card--primary::before { border-color: var(--primary); }\n        .card--secondary::before { border-color: var(--secondary); }\n        .card--accent-green::before { border-color: var(--accent-green); }\n\n        .card-icon-wrapper {\n            width: 48px; height: 48px;\n            display: flex; align-items: center; justify-content: center;\n            margin-bottom: 24px;\n        }\n\n        .card--primary .card-icon-wrapper i { color: var(--primary); }\n        .card--secondary .card-icon-wrapper i { color: var(--secondary); }\n        .card--accent-green .card-icon-wrapper i { color: var(--accent-green); }\n\n        .card h3 {\n            font-size: 24px;\n            font-weight: 600;\n            line-height: 1.3;\n            margin: 0 0 12px 0;\n            color: var(--text);\n        }\n\n        .card p {\n            font-size: 16px;\n            font-weight: 400;\n            line-height: 1.5;\n            color: var(--text-muted);\n            margin: 0 0 24px 0;\n            flex-grow: 1; /* Push status to bottom */\n        }\n\n        .status {\n            display: flex;\n            align-items: center;\n            font-size: 13px;\n            font-weight: 600;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n            color: var(--text-muted);\n        }\n\n        .status-dot {\n            width: 8px;\n            height: 8px;\n            border-radius: 50%;\n            margin-right: 8px;\n        }\n\n        .card--primary .status-dot { background-color: var(--primary); }\n        .card--secondary .status-dot { background-color: var(--secondary); }\n        .card--accent-green .status-dot { background-color: var(--accent-green); }\n\n        /* Footer */\n        .footer {\n            position: absolute;\n            bottom: 40px;\n            left: 72px;\n            right: 72px;\n            display: flex;\n            justify-content: space-between;\n            font-size: 13px;\n            color: var(--text-muted);\n            font-weight: 400;\n            letter-spacing: 0.5px;\n            z-index: 1; /* Ensure footer is above background pattern */\n        }\n\n        .footer span:last-child {\n            display: flex;\n            align-items: center;\n            gap: 4px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"slide\">\n        <div class=\"subheadline\">{{subheadline}}</div>\n        <h1 class=\"headline\">{{headline}}</h1>\n        <p class=\"body-text\">{{body}}</p>\n\n        <div class=\"cards-container\">\n            <div class=\"card card--primary\">\n                <div class=\"card-icon-wrapper\">\n                    <i data-lucide=\"file-text\" style=\"width:48px;height:48px\"></i>\n                </div>\n                <h3>{{card1_title}}</h3>\n                <p>{{card1_description}}</p>\n                <div class=\"status\">\n                    <span class=\"status-dot\"></span>\n                    <span>ACTIVE</span>\n                </div>\n            </div>\n\n            <div class=\"card card--secondary\">\n                <div class=\"card-icon-wrapper\">\n                    <i data-lucide=\"code\" style=\"width:48px;height:48px\"></i>\n                </div>\n                <h3>{{card2_title}}</h3>\n                <p>{{card2_description}}</p>\n                <div class=\"status\">\n                    <span class=\"status-dot\"></span>\n                    <span>ACTIVE</span>\n                </div>\n            </div>\n\n            <div class=\"card card--accent-green\">\n                <div class=\"card-icon-wrapper\">\n                    <i data-lucide=\"calendar\" style=\"width:48px;height:48px\"></i>\n                </div>\n                <h3>{{card3_title}}</h3>\n                <p>{{card3_description}}</p>\n                <div class=\"status\">\n                    <span class=\"status-dot\"></span>\n                    <span>ACTIVE</span>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <div class=\"footer\">\n        <span>Instagram<br>{{brand_name}}</span>\n        <span>Swipe to Know More &rarr;</span>\n    </div>\n\n    <script>\n        lucide.createIcons();\n    </script>\n</body>\n</html>",
