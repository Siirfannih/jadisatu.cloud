      "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Design Conversion</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');\n\n        :root {\n            --bg: #F5F5F0;\n            --primary: #1ABC9C; /* Teal for dotted lines */\n            --secondary: #E0E0E0; /* Light grey for outer circle borders */\n            --accent: #1A1A1A; /* Dark text for main headline, bold 'twelve' */\n            --text: #333333; /* General body text */\n            --text-muted: #888888; /* Muted grey for \"Zero\", subheadline, footer, background shapes */\n            --surface: #FFFFFF; /* For the outer circles */\n            --central-circle-bg: #000000; /* Black for central circle */\n            --central-circle-text: #FFFFFF; /* White for central circle text */\n        }\n\n        body {\n            margin: 0;\n            padding: 0;\n            width: 1080px;\n            height: 1080px;\n            overflow: hidden;\n            background: var(--bg);\n            font-family: 'Inter', sans-serif;\n            color: var(--text);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .slide {\n            width: 1080px;\n            height: 1080px;\n            padding: 60px 72px;\n            box-sizing: border-box;\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between; /* Distribute content vertically */\n            position: relative;\n            align-items: flex-start; /* Align content to the left */\n        }\n\n        /* Decorative Background Elements */\n        .bg-shape {\n            position: absolute;\n            opacity: 0.3;\n            pointer-events: none;\n            z-index: 0;\n        }\n\n        /* Top-right line and dots */\n        .bg-shape.top-right-line {\n            top: 100px;\n            right: 100px;\n            width: 50px;\n            height: 0;\n            border-top: 1px solid var(--text-muted);\n            transform: rotate(-45deg);\n            transform-origin: top right;\n        }\n        .bg-shape.top-right-dot-1 { top: 100px; right: 100px; width: 4px; height: 4px; background: var(--text-muted); border-radius: 50%; }\n        .bg-shape.top-right-dot-2 { top: 120px; right: 120px; width: 4px; height: 4px; background: var(--text-muted); border-radius: 50%; }\n        .bg-shape.top-right-dot-3 { top: 140px; right: 140px; width: 4px; height: 4px; background: var(--text-muted); border-radius: 50%; }\n\n        /* Bottom-left line and dots */\n        .bg-shape.bottom-left-line {\n            bottom: 100px;\n            left: 100px;\n            width: 50px;\n            height: 0;\n            border-top: 1px solid var(--text-muted);\n            transform: rotate(135deg);\n            transform-origin: bottom left;\n        }\n        .bg-shape.bottom-left-dot-1 { bottom: 100px; left: 100px; width: 4px; height: 4px; background: var(--text-muted); border-radius: 50%; }\n        .bg-shape.bottom-left-dot-2 { bottom: 120px; left: 120px; width: 4px; height: 4px; background: var(--text-muted); border-radius: 50%; }\n        .bg-shape.bottom-left-dot-3 { bottom: 140px; left: 140px; width: 4px; height: 4px; background: var(--text-muted); border-radius: 50%; }\n\n        /* Bottom-right line and dots */\n        .bg-shape.bottom-right-line {\n            bottom: 100px;\n            right: 100px;\n            width: 50px;\n            height: 0;\n            border-top: 1px solid var(--text-muted);\n            transform: rotate(-135deg);\n            transform-origin: bottom right;\n        }\n        .bg-shape.bottom-right-dot-1 { bottom: 100px; right: 100px; width: 4px; height: 4px; background: var(--text-muted); border-radius: 50%; }\n        .bg-shape.bottom-right-dot-2 { bottom: 120px; right: 120px; width: 4px; height: 4px; background: var(--text-muted); border-radius: 50%; }\n        .bg-shape.bottom-right-dot-3 { bottom: 140px; right: 140px; width: 4px; height: 4px; background: var(--text-muted); border-radius: 50%; }\n\n\n        .subheadline {\n            font-size: 14px;\n            font-weight: 500;\n            color: var(--text-muted);\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            margin-bottom: 20px;\n        }\n\n        .headline {\n            font-size: 96px;\n            font-weight: 800;\n            color: var(--accent);\n            line-height: 1.1;\n            margin: 0;\n        }\n\n        .highlight-muted {\n            color: var(--text-muted);\n            font-weight: 800;\n        }\n\n        .body-text {\n            font-size: 28px;\n            font-weight: 400;\n            color: var(--text);\n            line-height: 1.4;\n            margin: 0;\n        }\n\n        .highlight {\n            font-weight: 700;\n            color: var(--accent);\n        }\n\n        .footer {\n            position: absolute;\n            bottom: 40px;\n            left: 72px;\n            right: 72px;\n            display: flex;\n            justify-content: space-between;\n            font-size: 13px;\n            color: var(--text-muted);\n            line-height: 1.5;\n            z-index: 1; /* Ensure footer is above background shapes */\n        }\n\n        /* Diagram Styles */\n        .diagram-wrapper {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 500px; /* Container for positioning */\n            height: 500px; /* Container for positioning */\n            z-index: 1;\n        }\n\n        .central-node {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 100px; /* Slightly larger than outer circles */\n            height: 100px;\n            border-radius: 50%;\n            background: var(--central-circle-bg);\n            color: var(--central-circle-text);\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            font-size: 20px;\n            font-weight: 700;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n            z-index: 2;\n        }\n\n        .central-node::before {\n            content: '';\n            position: absolute;\n            top: -10px;\n            left: -10px;\n            right: -10px;\n            bottom: -10px;\n            border: 2px dotted var(--primary);\n            border-radius: 50%;\n            z-index: 1;\n        }\n\n        .diagram-line {\n            position: absolute;\n            width: 110px; /* Length of the dotted line segment */\n            height: 2px; /* Visual thickness of the line */\n            border-top: 2px dotted var(--primary);\n            top: 50%;\n            left: 50%;\n            transform-origin: 0% 50%; /* Rotate around its own left edge */\n            /* Translate to start 50px from center (central circle radius)\n               and adjust for line height (2px) to be vertically centered */\n            transform: translate(50px, -1px) rotate(var(--line-angle));\n            z-index: 1;\n        }\n\n        .outer-node {\n            position: absolute;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            text-align: center;\n            gap: 8px;\n            z-index: 2;\n            /* Calculate position relative to diagram-wrapper center */\n            top: calc(50% + var(--node-distance) * sin(var(--node-angle)));\n            left: calc(50% + var(--node-distance) * cos(var(--node-angle)));\n            /* Center the node itself on the calculated point */\n            transform: translate(-50%, -50%);\n        }\n\n        .hub-circle {\n            width: 80px;\n            height: 80px;\n            border-radius: 50%;\n            border: 2px solid var(--secondary);\n            background: var(--surface);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            box-sizing: border-box;\n        }\n\n        .outer-node .label {\n            font-size: 12px;\n            font-weight: 500;\n            color: var(--text);\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n        }\n\n        /* Lucide icon styling */\n        .hub-circle i {\n            width: 24px;\n            height: 24px;\n            color: var(--accent); /* Icons are dark */\n        }\n    </style>\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n</head>\n<body>\n    <div class=\"slide\">\n        <!-- Background Decorative Shapes -->\n        <div class=\"bg-shape top-right-line\"></div>\n        <div class=\"bg-shape top-right-dot-1\"></div>\n        <div class=\"bg-shape top-right-dot-2\"></div>\n        <div class=\"bg-shape top-right-dot-3\"></div>\n\n        <div class=\"bg-shape bottom-left-line\"></div>\n        <div class=\"bg-shape bottom-left-dot-1\"></div>\n        <div class=\"bg-shape bottom-left-dot-2\"></div>\n        <div class=\"bg-shape bottom-left-dot-3\"></div>\n\n        <div class=\"bg-shape bottom-right-line\"></div>\n        <div class=\"bg-shape bottom-right-dot-1\"></div>\n        <div class=\"bg-shape bottom-right-dot-2\"></div>\n        <div class=\"bg-shape bottom-right-dot-3\"></div>\n\n        <div class=\"top-content\">\n            <div class=\"subheadline\">{{subheadline}}</div>\n            <h1 class=\"headline\">\n                {{headline | replace('Zero', '<span class=\"highlight-muted\">Zero</span>') | safe}}\n            </h1>\n        </div>\n\n        <div class=\"diagram-wrapper\">\n            <div class=\"central-node\">YOU</div>\n\n            <!-- Diagram Lines -->\n            <div class=\"diagram-line\" style=\"--line-angle: 30deg;\"></div>\n            <div class=\"diagram-line\" style=\"--line-angle: 0deg;\"></div>\n            <div class=\"diagram-line\" style=\"--line-angle: -30deg;\"></div>\n            <div class=\"diagram-line\" style=\"--line-angle: -150deg;\"></div>\n            <div class=\"diagram-line\" style=\"--line-angle: 180deg;\"></div>\n            <div class=\"diagram-line\" style=\"--line-angle: 150deg;\"></div>\n\n            <!-- Outer Nodes -->\n            <div class=\"outer-node\" style=\"--node-angle: 30deg; --node-distance: 200px;\">\n                <div class=\"hub-circle\"><i data-lucide=\"mail\"></i></div>\n                <div class=\"label\">EMAIL</div>\n            </div>\n            <div class=\"outer-node\" style=\"--node-angle: 0deg; --node-distance: 200px;\">\n                <div class=\"hub-circle\"><i data-lucide=\"code\"></i></div>\n                <div class=\"label\">CODE</div>\n            </div>\n            <div class=\"outer-node\" style=\"--node-angle: -30deg; --node-distance: 200px;\">\n                <div class=\"hub-circle\"><i data-lucide=\"dollar-sign\"></i></div>\n                <div class=\"label\">FINANCE</div>\n            </div>\n            <div class=\"outer-node\" style=\"--node-angle: -150deg; --node-distance: 200px;\">\n                <div class=\"hub-circle\"><i data-lucide=\"calendar\"></i></div>\n                <div class=\"label\">SCHED</div>\n            </div>\n            <div class=\"outer-node\" style=\"--node-angle: 180deg; --node-distance: 200px;\">\n                <div class=\"hub-circle\"><i data-lucide=\"file-text\"></i></div>\n                <div class=\"label\">DOCS</div>\n            </div>\n            <div class=\"outer-node\" style=\"--node-angle: 150deg; --node-distance: 200px;\">\n                <div class=\"hub-circle\"><i data-lucide=\"message-square\"></i></div>\n                <div class=\"label\">COMMS</div>\n            </div>\n        </div>\n\n        <div class=\"bottom-content\">\n            <p class=\"body-text\">\n                {{body | replace('twelve', '<span class=\"highlight\">twelve</span>') | safe}}\n            </p>\n        </div>\n\n        <div class=\"footer\">\n            <span>Instagram<br>{{brand_name}}</span>\n            <span>Swipe to Know More \u2192</span>\n        </div>\n    </div>\n\n    <script>\n        lucide.createIcons();\n    </script>\n</body>\n</html>",
