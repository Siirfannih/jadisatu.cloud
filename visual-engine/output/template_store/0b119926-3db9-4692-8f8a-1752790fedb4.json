    {
      "name": "dark-editorial",
      "description": "AI-extracted template from reference design",
      "html": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Design Conversion</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,700;1,400&family=Montserrat:wght@300;400;700&display=swap');\n\n        :root {\n            --bg: #000000;\n            --primary: #FFFFFF; /* Main text color */\n            --text: #FFFFFF;\n            --text-muted: #AAAAAA; /* Not explicitly used in this design */\n            --surface: #000000; /* No distinct surfaces */\n            --accent: #FFFFFF; /* No distinct accent color */\n        }\n\n        body {\n            margin: 0;\n            padding: 0;\n            width: 1080px;\n            height: 1080px;\n            background-color: var(--bg);\n            color: var(--text);\n            font-family: 'Lora', serif; /* Default for body text */\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between;\n            box-sizing: border-box; /* Include padding in width/height */\n            padding: 80px 120px; /* Overall padding for the content area */\n        }\n\n        .header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            width: 100%;\n            margin-bottom: 80px; /* Space between header and main content */\n        }\n\n        .header-left {\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 300;\n            font-size: 14px;\n            letter-spacing: 2px;\n            text-transform: uppercase;\n            line-height: 1;\n        }\n\n        .header-right {\n            /* This is a stylized logo/text. Recreating with CSS shapes is not feasible.\n               Representing as text with a comment as per instructions for non-standard elements. */\n            font-family: 'Montserrat', sans-serif; /* Fallback font, as exact match is hard */\n            font-weight: 400; /* Visually appears medium weight */\n            font-size: 32px; /* Adjusted to visually match the size */\n            line-height: 1;\n            color: var(--text);\n            /* LOGO_AREA: Stylized Chinese characters logo */\n            /* The characters appear to be \"\u624b\u6284\u672c\" */\n        }\n\n        .main-content {\n            flex-grow: 1;\n            display: flex;\n            flex-direction: column;\n            justify-content: center; /* Center content vertically */\n            width: 600px; /* Approximate width for the text block */\n            margin: 0 auto; /* Center horizontally within the available space */\n            text-align: left;\n        }\n\n        h1 {\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 700;\n            font-size: 40px;\n            letter-spacing: 2px;\n            text-transform: uppercase;\n            margin-bottom: 30px; /* Space between headline and body */\n            line-height: 1.2;\n            margin-top: 0; /* Reset default margin */\n        }\n\n        p {\n            font-family: 'Lora', serif;\n            font-weight: 400;\n            font-size: 30px;\n            line-height: 1.5;\n            margin: 0;\n        }\n\n        .footer {\n            display: flex;\n            justify-content: space-between;\n            align-items: flex-end;\n            width: 100%;\n            margin-top: 80px; /* Space between main content and footer */\n        }\n\n        .footer-left, .footer-right {\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 300;\n            font-size: 12px;\n            line-height: 1.5;\n            color: var(--text);\n        }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <div class=\"header-left\">{{brand_name}}</div>\n        <div class=\"header-right\"><!-- LOGO_AREA: Stylized Chinese characters logo -->\u624b\u6284\u672c</div>\n    </div>\n\n    <div class=\"main-content\">\n        <h1>{{headline}}</h1>\n        <p>{{body}}</p>\n    </div>\n\n    <div class=\"footer\">\n        <div class=\"footer-left\">\n            Alan Hong<br>\n            @thealanhong\n        </div>\n        <div class=\"footer-right\">\n            &copy; The Codexx 2026<br>\n            www.thecodexx.com\n        </div>\n    </div>\n\n    <!-- Lucide icons script - included as per requirement, though no icons are present in this design -->\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <script>\n        lucide.createIcons();\n    </script>\n</body>\n</html>",
