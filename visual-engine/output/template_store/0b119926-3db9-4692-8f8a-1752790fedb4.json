    {
      "name": "dark-modern",
      "description": "AI-extracted template from reference design",
      "html": "<!DOCTYPE html>\n<html>\n<head>\n<title>Design Conversion</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Montserrat:wght@700&family=Ma+Shan+Zheng&display=swap\" rel=\"stylesheet\">\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Montserrat:wght@700&family=Ma+Shan+Zheng&display=swap');\n\n  :root {\n    --bg: #000000;\n    --primary: #FFFFFF;\n    --text: #FFFFFF;\n    --text-muted: #AAAAAA;\n    --font-headline: 'Montserrat', sans-serif;\n    --font-body: 'Inter', sans-serif;\n    --font-script: 'Ma Shan Zheng', cursive;\n  }\n\n  body {\n    margin: 0;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    min-height: 100vh;\n    background-color: #333; /* A neutral background for the page itself */\n    font-family: var(--font-body);\n    color: var(--text);\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n\n  #app {\n    width: 1080px;\n    height: 1080px;\n    background-color: var(--bg);\n    display: flex;\n    flex-direction: column;\n    box-sizing: border-box;\n    padding: 60px 80px; /* Top/bottom, Left/Right padding */\n    position: relative;\n    overflow: hidden; /* Ensures content stays within bounds */\n  }\n\n  .header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 80px; /* Space below the header */\n  }\n\n  .header-left {\n    font-family: var(--font-body);\n    font-weight: 700;\n    font-size: 24px;\n    letter-spacing: 2px;\n    color: var(--primary);\n  }\n\n  .header-right {\n    font-family: var(--font-script);\n    font-size: 48px; /* Larger size for the script font */\n    color: var(--primary);\n    line-height: 1; /* Adjust line-height for script font */\n  }\n\n  .main-content {\n    flex-grow: 1;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n    padding-bottom: 40px; /* Space above the footer */\n  }\n\n  .headline {\n    font-family: var(--font-headline);\n    font-weight: 700;\n    font-size: 48px;\n    margin-bottom: 16px;\n    line-height: 1.2;\n  }\n\n  .subheadline {\n    font-family: var(--font-body);\n    font-weight: 400;\n    font-size: 20px;\n    color: var(--text);\n    max-width: 600px; /* Constrain width for readability */\n    margin-bottom: 80px; /* Space above the diagram */\n  }\n\n  .diagram-container {\n    width: 100%;\n    flex-grow: 1;\n    display: flex;\n    justify-content: center;\n    align-items: flex-start; /* Align diagram to the top of its container */\n    position: relative;\n  }\n\n  .footer {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-end;\n    font-size: 14px;\n    color: var(--text-muted);\n    margin-top: auto; /* Pushes the footer to the bottom */\n  }\n\n  .footer-left {\n    line-height: 1.4;\n    text-align: left;\n  }\n  .footer-right {\n    line-height: 1.4;\n    text-align: right;\n  }\n\n  /* SVG Styling */\n  .diagram-svg {\n    width: 900px; /* Adjusted to fit within 1080px width with padding */\n    height: 600px; /* Adjusted height */\n    overflow: visible; /* Allows text labels to extend beyond SVG bounds if needed */\n  }\n\n  .diagram-path {\n    fill: none;\n    stroke: var(--primary);\n    stroke-width: 2px;\n  }\n\n  .diagram-point {\n    fill: var(--primary);\n    stroke: var(--primary);\n    stroke-width: 2px;\n  }\n\n  .diagram-point-outline {\n    fill: none;\n    stroke: var(--primary);\n    stroke-width: 2px;\n  }\n\n  .diagram-dashed-line {\n    stroke: var(--primary);\n    stroke-width: 1px;\n    stroke-dasharray: 8 8; /* Creates a dashed line */\n  }\n\n  .diagram-label {\n    font-family: var(--font-body);\n    font-size: 16px;\n    fill: var(--primary);\n    text-anchor: middle;\n  }\n\n  .diagram-label-rotated {\n    font-family: var(--font-body);\n    font-size: 16px;\n    fill: var(--primary);\n    text-anchor: middle;\n  }\n\n  .diagram-inner-work {\n    font-family: var(--font-headline);\n    font-weight: 700;\n    font-size: 28px;\n    fill: var(--primary);\n    text-anchor: middle;\n  }\n\n  .diagram-visible-hidden {\n    font-family: var(--font-body);\n    font-weight: 700;\n    font-size: 18px;\n    fill: var(--primary);\n    text-anchor: end; /* Aligns text to the right of its x-coordinate */\n  }\n\n  /* Pattern for hatched area */\n  .hatched-fill {\n    fill: url(#diagonalHatch);\n  }\n\n  /* Specific styles for the \"The Inherited Life\" and \"The Sovereign Life\" labels */\n  .life-label {\n    font-family: var(--font-body);\n    font-weight: 700;\n    font-size: 20px;\n    fill: var(--primary);\n    text-anchor: start;\n  }\n  .life-label.right {\n    text-anchor: end;\n  }\n\n</style>\n</head>\n<body>\n  <div id=\"app\">\n    <div class=\"header\">\n      <div class=\"header-left\">{{brand_name}}</div>\n      <div class=\"header-right\">\u624b\u6284\u672c</div>\n    </div>\n\n    <div class=\"main-content\">\n      <h1 class=\"headline\">{{headline}}</h1>\n      <p class=\"subheadline\">{{subheadline}}</p>\n\n      <div class=\"diagram-container\">\n        <svg class=\"diagram-svg\" viewBox=\"0 0 1000 600\">\n          <defs>\n            <pattern id=\"diagonalHatch\" patternUnits=\"userSpaceOnUse\" width=\"10\" height=\"10\" patternTransform=\"rotate(45)\">\n              <line x1=\"0\" y1=\"0\" x2=\"0\" y2=\"10\" stroke=\"white\" stroke-width=\"1.5\"/>\n            </pattern>\n          </defs>\n\n          <!-- The main arc path (cubic bezier for smoother control) -->\n          <path class=\"diagram-path\" d=\"M 150 150 C 100 250 200 400 350 450 C 400 480 600 480 650 450 C 800 400 900 250 850 150\" />\n\n          <!-- Dashed horizontal line -->\n          <line class=\"diagram-dashed-line\" x1=\"100\" y1=\"300\" x2=\"900\" y2=\"300\" />\n\n          <!-- Hatched area path (approximated to follow the arc segment from y=300 down and back up) -->\n          <path class=\"hatched-fill\" d=\"M 280 300 C 250 350 300 400 350 450 C 400 480 600 480 650 450 C 700 400 750 350 720 300 Z\" />\n\n          <!-- Labels for Visible/Hidden -->\n          <text class=\"diagram-visible-hidden\" x=\"95\" y=\"285\">Visible</text>\n          <text class=\"diagram-visible-hidden\" x=\"95\" y=\"325\">Hidden</text>\n\n          <!-- The Inherited Life / The Sovereign Life labels -->\n          <text class=\"life-label\" x=\"150\" y=\"120\">The Inherited Life</text>\n          <text class=\"life-label right\" x=\"850\" y=\"120\">The Sovereign Life</text>\n\n          <!-- Points and Labels -->\n          <!-- Dissonance (outlined) -->\n          <circle class=\"diagram-point-outline\" cx=\"150\" cy=\"150\" r=\"6\" />\n          <text class=\"diagram-label-rotated\" x=\"220\" y=\"240\" transform=\"rotate(-45 220 240)\">Dissonance</text>\n\n          <!-- Rupture (filled) -->\n          <circle class=\"diagram-point\" cx=\"300\" cy=\"290\" r=\"6\" />\n          <text class=\"diagram-label\" x=\"300\" y=\"270\">Rupture</text>\n\n          <!-- Dissolution (filled) -->\n          <circle class=\"diagram-point\" cx=\"350\" cy=\"380\" r=\"6\" />\n          <text class=\"diagram-label-rotated\" x=\"320\" y=\"410\" transform=\"rotate(-45 320 410)\">Dissolution</text>\n\n          <!-- Rebellion (filled) -->\n          <circle class=\"diagram-point\" cx=\"400\" cy=\"450\" r=\"6\" />\n          <text class=\"diagram-label\" x=\"400\" y=\"475\">Rebellion</text>\n\n          <!-- Regret (filled) -->\n          <circle class=\"diagram-point\" cx=\"500\" cy=\"480\" r=\"6\" />\n          <text class=\"diagram-label\" x=\"500\" y=\"505\">Regret</text>\n\n          <!-- Regulation (filled) -->\n          <circle class=\"diagram-point\" cx=\"600\" cy=\"450\" r=\"6\" />\n          <text class=\"diagram-label\" x=\"600\" y=\"475\">Regulation</text>\n\n          <!-- Integration (filled) -->\n          <circle class=\"diagram-point\" cx=\"650\" cy=\"380\" r=\"6\" />\n          <text class=\"diagram-label-rotated\" x=\"680\" y=\"410\" transform=\"rotate(45 680 410)\">Integration</text>\n\n          <!-- Recalibration (filled) -->\n          <circle class=\"diagram-point\" cx=\"700\" cy=\"290\" r=\"6\" />\n          <text class=\"diagram-label\" x=\"700\" y=\"270\">Recalibration</text>\n\n          <!-- Rebirth (filled) -->\n          <circle class=\"diagram-point\" cx=\"720\" cy=\"270\" r=\"6\" />\n          <text class=\"diagram-label\" x=\"720\" y=\"250\">Rebirth</text>\n\n          <!-- Emergence (outlined) -->\n          <circle class=\"diagram-point-outline\" cx=\"850\" cy=\"150\" r=\"6\" />\n          <text class=\"diagram-label-rotated\" x=\"780\" y=\"240\" transform=\"rotate(45 780 240)\">Emergence</text>\n\n          <!-- Inner Work label -->\n          <text class=\"diagram-inner-work\" x=\"500\" y=\"350\">Inner Work</text>\n\n        </svg>\n      </div>\n    </div>\n\n    <div class=\"footer\">\n      <div class=\"footer-left\">\n        Alan Hong<br>@thealanhong\n      </div>\n      <div class=\"footer-right\">\n        &copy;The Codexx 2026<br>www.thecodexx.com\n      </div>\n    </div>\n  </div>\n</body>\n</html>",
