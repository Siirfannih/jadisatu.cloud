      "html": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Design Conversion</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,700;1,400&display=swap');\n\n        :root {\n            --bg: #F5F4F0;\n            --primary: #212121; /* Main dark text */\n            --secondary: #D9D9D9; /* Light grey for inactive cards and background lines */\n            --accent: #38C172; /* Green highlight and active card */\n            --text: #212121; /* General text color */\n            --text-muted: #888888; /* Footer and subtle text */\n            --surface-light: #D9D9D9; /* Light grey card background */\n            --surface-dark: #212121; /* Dark card background */\n            --surface-accent: #38C172; /* Accent card background */\n            --shadow-color: rgba(0, 0, 0, 0.15);\n            --shadow-color-lg: rgba(0, 0, 0, 0.1);\n        }\n\n        body {\n            margin: 0;\n            padding: 0;\n            width: 1080px;\n            height: 1080px;\n            overflow: hidden;\n            background: var(--bg);\n            font-family: 'Inter', sans-serif;\n            color: var(--text);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            position: relative; /* For background elements */\n        }\n\n        .slide {\n            width: 1080px;\n            height: 1080px;\n            padding: 60px 72px;\n            box-sizing: border-box;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            position: relative;\n            gap: 60px; /* Space between text block and cards */\n        }\n\n        .headline-group {\n            display: flex;\n            flex-direction: column;\n            gap: 16px; /* Space between headline and number */\n        }\n\n        .headline {\n            font-size: 96px;\n            font-weight: 700;\n            line-height: 1.1;\n            color: var(--primary);\n            margin: 0;\n        }\n\n        .highlight {\n            color: var(--accent);\n            font-style: italic;\n        }\n\n        .number {\n            font-size: 140px;\n            font-weight: 700;\n            line-height: 1;\n            color: var(--primary);\n            margin: 0;\n            position: relative;\n            padding-bottom: 10px; /* Space for the underline */\n        }\n\n        .number::after {\n            content: '';\n            position: absolute;\n            left: 0;\n            bottom: 0;\n            width: 100px; /* Length of the underline */\n            height: 6px; /* Thickness of the underline */\n            background-color: var(--accent);\n            border-radius: 3px;\n        }\n\n        .body-text {\n            font-size: 24px;\n            font-weight: 400;\n            color: var(--primary);\n            margin: 0;\n            margin-top: 10px; /* Space below the number */\n        }\n\n        .card-container {\n            display: flex;\n            gap: 24px; /* Space between cards */\n            justify-content: center;\n            margin-top: 60px; /* Space between body text and cards */\n        }\n\n        .card-3d {\n            width: 120px;\n            height: 120px;\n            border-radius: 16px;\n            box-shadow: 0 4px 0 var(--shadow-color), 0 8px 20px var(--shadow-color-lg);\n            transform: perspective(500px) rotateX(2deg);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            gap: 8px;\n            transition: transform 0.2s ease-out, box-shadow 0.2s ease-out;\n            cursor: pointer;\n        }\n\n        .card-3d:hover {\n            transform: perspective(500px) rotateX(0deg) translateY(-5px);\n            box-shadow: 0 8px 0 var(--shadow-color), 0 16px 30px var(--shadow-color-lg);\n        }\n\n        .card-light {\n            background: var(--surface-light);\n            color: var(--primary);\n        }\n\n        .card-dark {\n            background: var(--surface-dark);\n            color: var(--bg); /* Light text on dark background */\n        }\n\n        .card-accent {\n            background: var(--surface-accent);\n            color: var(--primary); /* Dark text on accent background */\n        }\n\n        .card-label {\n            font-size: 12px;\n            font-weight: 400;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n        }\n\n        .footer {\n            position: absolute;\n            bottom: 40px;\n            left: 72px;\n            right: 72px;\n            display: flex;\n            justify-content: space-between;\n            font-size: 13px;\n            color: var(--text-muted);\n            font-weight: 400;\n        }\n\n        /* Background decorative lines */\n        .bg-line {\n            position: absolute;\n            border-top: 2px solid var(--secondary);\n            opacity: 0.3;\n            pointer-events: none;\n            z-index: -1;\n        }\n\n        .bg-line-1 { top: 100px; left: 70%; width: 150px; transform: rotate(30deg); }\n        .bg-line-2 { top: 200px; left: 80%; width: 100px; transform: rotate(-15deg); }\n        .bg-line-3 { top: 300px; left: 60%; width: 200px; transform: rotate(45deg); }\n        .bg-line-4 { bottom: 150px; left: 10%; width: 180px; transform: rotate(-20deg); }\n        .bg-line-5 { bottom: 250px; left: 20%; width: 120px; transform: rotate(10deg); }\n        .bg-line-6 { top: 50%; left: 5%; width: 100px; transform: rotate(60deg); }\n        .bg-line-7 { bottom: 50px; right: 10%; width: 150px; transform: rotate(-30deg); }\n        .bg-line-8 { top: 400px; right: 5%; width: 100px; transform: rotate(20deg); }\n        .bg-line-9 { top: 600px; right: 15%; width: 180px; transform: rotate(-40deg); }\n        .bg-line-10 { top: 800px; left: 30%; width: 120px; transform: rotate(15deg); }\n\n        /* Small dots for background */\n        .bg-dot {\n            position: absolute;\n            width: 4px;\n            height: 4px;\n            background-color: var(--secondary);\n            border-radius: 50%;\n            opacity: 0.3;\n            pointer-events: none;\n            z-index: -1;\n        }\n        .bg-dot-1 { top: 90px; left: 69%; }\n        .bg-dot-2 { top: 110px; left: 78%; }\n        .bg-dot-3 { top: 130px; left: 65%; }\n        .bg-dot-4 { top: 150px; left: 75%; }\n        .bg-dot-5 { top: 170px; left: 85%; }\n\n        .bg-dot-6 { bottom: 140px; left: 9%; }\n        .bg-dot-7 { bottom: 160px; left: 18%; }\n        .bg-dot-8 { bottom: 180px; left: 12%; }\n        .bg-dot-9 { bottom: 200px; left: 22%; }\n        .bg-dot-10 { bottom: 220px; left: 15%; }\n\n        .bg-dot-11 { top: 390px; right: 4%; }\n        .bg-dot-12 { top: 410px; right: 13%; }\n        .bg-dot-13 { top: 430px; right: 7%; }\n        .bg-dot-14 { top: 450px; right: 17%; }\n        .bg-dot-15 { top: 470px; right: 10%; }\n\n        .bg-dot-16 { top: 590px; right: 14%; }\n        .bg-dot-17 { top: 610px; right: 23%; }\n        .bg-dot-18 { top: 630px; right: 17%; }\n        .bg-dot-19 { top: 650px; right: 27%; }\n        .bg-dot-20 { top: 670px; right: 20%; }\n\n        .bg-dot-21 { top: 790px; left: 29%; }\n        .bg-dot-22 { top: 810px; left: 38%; }\n        .bg-dot-23 { top: 830px; left: 32%; }\n        .bg-dot-24 { top: 850px; left: 42%; }\n        .bg-dot-25 { top: 870px; left: 35%; }\n\n    </style>\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n</head>\n<body>\n    <div class=\"slide\">\n        <div class=\"headline-group\">\n            <h1 class=\"headline\">\n                The first real AI employee is <span class=\"highlight\">here.</span>\n            </h1>\n            <p class=\"number\">145K</p>\n            <p class=\"body-text\">{{body}}</p>\n        </div>\n\n        <div class=\"card-container\">\n            <div class=\"card-3d card-light\">\n                <i data-lucide=\"mail\" style=\"width:48px;height:48px; color: var(--primary);\"></i>\n                <span class=\"card-label\">EMAIL</span>\n            </div>\n            <div class=\"card-3d card-dark\">\n                <i data-lucide=\"bot\" style=\"width:48px;height:48px; color: var(--accent);\"></i>\n                <span class=\"card-label\" style=\"color: var(--bg);\">AGENT</span>\n            </div>\n            <div class=\"card-3d card-accent\">\n                <i data-lucide=\"calendar\" style=\"width:48px;height:48px; color: var(--primary);\"></i>\n                <span class=\"card-label\">SCHEDULE</span>\n            </div>\n            <div class=\"card-3d card-light\">\n                <i data-lucide=\"code\" style=\"width:48px;height:48px; color: var(--primary);\"></i>\n                <span class=\"card-label\">CODE</span>\n            </div>\n        </div>\n\n        <div class=\"footer\">\n            <span>Instagram<br>{{brand_name}}</span>\n            <span>{{cta_text}} \u2192</span>\n        </div>\n    </div>\n\n    <!-- Background decorative elements -->\n    <div class=\"bg-line bg-line-1\"></div>\n    <div class=\"bg-line bg-line-2\"></div>\n    <div class=\"bg-line bg-line-3\"></div>\n    <div class=\"bg-line bg-line-4\"></div>\n    <div class=\"bg-line bg-line-5\"></div>\n    <div class=\"bg-line bg-line-6\"></div>\n    <div class=\"bg-line bg-line-7\"></div>\n    <div class=\"bg-line bg-line-8\"></div>\n    <div class=\"bg-line bg-line-9\"></div>\n    <div class=\"bg-line bg-line-10\"></div>\n\n    <div class=\"bg-dot bg-dot-1\"></div>\n    <div class=\"bg-dot bg-dot-2\"></div>\n    <div class=\"bg-dot bg-dot-3\"></div>\n    <div class=\"bg-dot bg-dot-4\"></div>\n    <div class=\"bg-dot bg-dot-5\"></div>\n    <div class=\"bg-dot bg-dot-6\"></div>\n    <div class=\"bg-dot bg-dot-7\"></div>\n    <div class=\"bg-dot bg-dot-8\"></div>\n    <div class=\"bg-dot bg-dot-9\"></div>\n    <div class=\"bg-dot bg-dot-10\"></div>\n    <div class=\"bg-dot bg-dot-11\"></div>\n    <div class=\"bg-dot bg-dot-12\"></div>\n    <div class=\"bg-dot bg-dot-13\"></div>\n    <div class=\"bg-dot bg-dot-14\"></div>\n    <div class=\"bg-dot bg-dot-15\"></div>\n    <div class=\"bg-dot bg-dot-16\"></div>\n    <div class=\"bg-dot bg-dot-17\"></div>\n    <div class=\"bg-dot bg-dot-18\"></div>\n    <div class=\"bg-dot bg-dot-19\"></div>\n    <div class=\"bg-dot bg-dot-20\"></div>\n    <div class=\"bg-dot bg-dot-21\"></div>\n    <div class=\"bg-dot bg-dot-22\"></div>\n    <div class=\"bg-dot bg-dot-23\"></div>\n    <div class=\"bg-dot bg-dot-24\"></div>\n    <div class=\"bg-dot bg-dot-25\"></div>\n\n\n    <script>\n        lucide.createIcons();\n    </script>\n</body>\n</html>",
