    {
      "name": "light-modern",
      "description": "AI-extracted template from reference design",
      "html": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Design Replication</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');\n\n        :root {\n            --bg: #f5f5f0;\n            --primary-dark: #000000; /* For the central 'YOU' circle */\n            --text: #222222;\n            --text-muted: #a0a0a0; /* For 'THE VISION', footer, icon labels */\n            --text-highlight-muted: #888888; /* For 'Zero employees' */\n            --accent: #00e080; /* Green outline, arrow */\n            --secondary-border: #dddddd; /* For the small hub circles' borders */\n            --surface: #ffffff; /* For the small hub circles' background */\n        }\n\n        body {\n            margin: 0;\n            padding: 0;\n            width: 1080px;\n            height: 1080px;\n            overflow: hidden;\n            background: var(--bg);\n            font-family: 'Inter', sans-serif;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .slide {\n            width: 1080px;\n            height: 1080px;\n            padding: 60px 72px;\n            box-sizing: border-box;\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between;\n            position: relative;\n        }\n\n        /* Header/Subheadline */\n        .header-section {\n            padding-top: 20px;\n        }\n\n        .subheadline {\n            font-size: 14px;\n            font-weight: 500;\n            color: var(--text-muted);\n            letter-spacing: 1px;\n            text-transform: uppercase;\n            margin-bottom: 10px;\n        }\n\n        .headline {\n            font-size: 72px;\n            font-weight: 800;\n            line-height: 1.1;\n            color: var(--text);\n            margin-bottom: 0;\n        }\n\n        .headline .muted {\n            color: var(--text-highlight-muted);\n            font-weight: 500;\n        }\n\n        /* Body text */\n        .body-text {\n            font-size: 28px;\n            line-height: 1.4;\n            color: var(--text);\n            font-weight: 500;\n            text-align: center;\n            margin-top: auto;\n            margin-bottom: 100px;\n            max-width: 600px;\n            align-self: center;\n        }\n\n        .body-text .highlight {\n            font-weight: 700;\n            color: var(--text);\n            font-style: normal; /* Override default italic if any */\n        }\n\n        /* Footer */\n        .footer {\n            position: absolute;\n            bottom: 40px;\n            left: 72px;\n            right: 72px;\n            display: flex;\n            justify-content: space-between;\n            align-items: flex-end;\n            font-size: 13px;\n            color: var(--text-muted);\n            font-weight: 500;\n        }\n\n        .footer .cta {\n            display: flex;\n            align-items: center;\n            gap: 8px;\n            color: var(--accent);\n            font-weight: 600;\n        }\n\n        /* Hub Diagram */\n        .hub-diagram {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            width: 600px;\n            height: 600px;\n        }\n\n        .hub-center {\n            width: 120px;\n            height: 120px;\n            border-radius: 50%;\n            background: var(--primary-dark);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: 600;\n            font-size: 18px;\n            position: relative;\n            z-index: 10;\n            box-shadow: 0 0 0 4px var(--accent); /* Green outline */\n        }\n\n        .hub-node {\n            position: absolute;\n            width: 80px;\n            height: 80px;\n            border-radius: 50%;\n            border: 2px solid var(--secondary-border);\n            background: var(--surface);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            font-size: 12px;\n            color: var(--text-muted);\n            font-weight: 500;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n            box-shadow: 0 2px 5px rgba(0,0,0,0.05); /* Subtle shadow for depth */\n        }\n\n        .hub-node i {\n            margin-bottom: 4px;\n            color: var(--text); /* Icons are dark */\n        }\n\n        /* Positioning for hub nodes relative to .hub-diagram (600x600) */\n        .hub-node-1 { top: 100px; left: 50%; transform: translateX(-50%); } /* Email */\n        .hub-node-2 { top: 180px; right: 100px; } /* Code */\n        .hub-node-3 { bottom: 180px; right: 100px; } /* Finance */\n        .hub-node-4 { bottom: 100px; left: 50%; transform: translateX(-50%); } /* Sched */\n        .hub-node-5 { bottom: 180px; left: 100px; } /* Docs */\n        .hub-node-6 { top: 180px; left: 100px; } /* Comms */\n\n        /* Dotted lines connecting hub nodes */\n        .hub-line {\n            position: absolute;\n            width: 100px; /* Approximate length of the dotted line segment */\n            height: 1px;\n            background: repeating-linear-gradient(to right, var(--text-muted) 0, var(--text-muted) 2px, transparent 2px, transparent 8px);\n            opacity: 0.4;\n            transform-origin: 0 50%; /* Rotate around its left edge */\n            z-index: 5;\n            top: 50%;\n            left: 50%;\n        }\n\n        /* Angles for 6 nodes, starting from top (90 deg) and going clockwise */\n        .hub-line-1 { transform: translate(0, -50%) rotate(-90deg) translateX(60px); } /* Email */\n        .hub-line-2 { transform: translate(0, -50%) rotate(-30deg) translateX(60px); } /* Code */\n        .hub-line-3 { transform: translate(0, -50%) rotate(30deg) translateX(60px); } /* Finance */\n        .hub-line-4 { transform: translate(0, -50%) rotate(90deg) translateX(60px); } /* Sched */\n        .hub-line-5 { transform: translate(0, -50%) rotate(150deg) translateX(60px); } /* Docs */\n        .hub-line-6 { transform: translate(0, -50%) rotate(-150deg) translateX(60px); } /* Comms */\n\n        /* Background geometric shapes */\n        .bg-shape {\n            position: absolute;\n            opacity: 0.1;\n            border: 1px solid var(--text-muted);\n            pointer-events: none;\n        }\n\n        .bg-shape.top-right {\n            width: 120px;\n            height: 120px;\n            top: 80px;\n            right: 80px;\n            transform: rotate(45deg);\n            border-radius: 4px;\n            border-bottom: none;\n            border-left: none;\n        }\n        .bg-shape.top-right::before {\n            content: '';\n            position: absolute;\n            width: 6px;\n            height: 6px;\n            background: var(--text-muted);\n            border-radius: 50%;\n            top: -3px;\n            left: -3px;\n        }\n        .bg-shape.top-right::after {\n            content: '';\n            position: absolute;\n            width: 6px;\n            height: 6px;\n            background: var(--text-muted);\n            border-radius: 50%;\n            bottom: -3px;\n            right: -3px;\n        }\n\n        .bg-shape.bottom-left {\n            width: 100px;\n            height: 100px;\n            bottom: 80px;\n            left: 80px;\n            transform: rotate(-30deg);\n            border-radius: 4px;\n            border-top: none;\n            border-right: none;\n        }\n        .bg-shape.bottom-left::before {\n            content: '';\n            position: absolute;\n            width: 6px;\n            height: 6px;\n            background: var(--text-muted);\n            border-radius: 50%;\n            top: -3px;\n            right: -3px;\n        }\n        .bg-shape.bottom-left::after {\n            content: '';\n            position: absolute;\n            width: 6px;\n            height: 6px;\n            background: var(--text-muted);\n            border-radius: 50%;\n            bottom: -3px;\n            left: -3px;\n        }\n\n        /* Additional small dots/lines in the background */\n        .bg-dot {\n            position: absolute;\n            width: 4px;\n            height: 4px;\n            background: var(--text-muted);\n            border-radius: 50%;\n            opacity: 0.1;\n            pointer-events: none;\n        }\n        .bg-dot.d1 { top: 180px; left: 100px; }\n        .bg-dot.d2 { top: 120px; left: 200px; }\n        .bg-dot.d3 { top: 220px; left: 250px; }\n        .bg-dot.d4 { bottom: 150px; right: 120px; }\n        .bg-dot.d5 { bottom: 200px; right: 200px; }\n\n        .bg-line-segment {\n            position: absolute;\n            height: 1px;\n            background: var(--text-muted);\n            opacity: 0.1;\n            pointer-events: none;\n        }\n        .bg-line-segment.l1 { width: 80px; top: 182px; left: 102px; transform: rotate(30deg); transform-origin: left center; }\n        .bg-line-segment.l2 { width: 60px; top: 122px; left: 202px; transform: rotate(-45deg); transform-origin: left center; }\n        .bg-line-segment.l3 { width: 70px; bottom: 152px; right: 122px; transform: rotate(-10deg); transform-origin: left center; }\n\n    </style>\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n</head>\n<body>\n    <div class=\"slide\">\n        <!-- Background geometric shapes -->\n        <div class=\"bg-shape top-right\"></div>\n        <div class=\"bg-shape bottom-left\"></div>\n        <div class=\"bg-dot d1\"></div>\n        <div class=\"bg-dot d2\"></div>\n        <div class=\"bg-dot d3\"></div>\n        <div class=\"bg-dot d4\"></div>\n        <div class=\"bg-dot d5\"></div>\n        <div class=\"bg-line-segment l1\"></div>\n        <div class=\"bg-line-segment l2\"></div>\n        <div class=\"bg-line-segment l3\"></div>\n\n\n        <div class=\"header-section\">\n            <p class=\"subheadline\">{{subheadline}}</p>\n            <h1 class=\"headline\">{{headline}}</h1>\n        </div>\n\n        <div class=\"hub-diagram\">\n            <div class=\"hub-center\">YOU</div>\n            <div class=\"hub-line hub-line-1\"></div>\n            <div class=\"hub-line hub-line-2\"></div>\n            <div class=\"hub-line hub-line-3\"></div>\n            <div class=\"hub-line hub-line-4\"></div>\n            <div class=\"hub-line hub-line-5\"></div>\n            <div class=\"hub-line hub-line-6\"></div>\n\n            <div class=\"hub-node hub-node-1\">\n                <i data-lucide=\"mail\" style=\"width:24px;height:24px\"></i>\n                <span>EMAIL</span>\n            </div>\n            <div class=\"hub-node hub-node-2\">\n                <i data-lucide=\"code\" style=\"width:24px;height:24px\"></i>\n                <span>CODE</span>\n            </div>\n            <div class=\"hub-node hub-node-3\">\n                <i data-lucide=\"dollar-sign\" style=\"width:24px;height:24px\"></i>\n                <span>FINANCE</span>\n            </div>\n            <div class=\"hub-node hub-node-4\">\n                <i data-lucide=\"calendar\" style=\"width:24px;height:24px\"></i>\n                <span>SCHED</span>\n            </div>\n            <div class=\"hub-node hub-node-5\">\n                <i data-lucide=\"file-text\" style=\"width:24px;height:24px\"></i>\n                <span>DOCS</span>\n            </div>\n            <div class=\"hub-node hub-node-6\">\n                <i data-lucide=\"message-square\" style=\"width:24px;height:24px\"></i>\n                <span>COMMS</span>\n            </div>\n        </div>\n\n        <p class=\"body-text\">{{body}}</p>\n\n        <div class=\"footer\">\n            <span>Instagram<br>{{brand_name}}</span>\n            <span class=\"cta\">{{cta_text}} <i data-lucide=\"arrow-right\" style=\"width:16px;height:16px\"></i></span>\n        </div>\n    </div>\n    <script>\n        lucide.createIcons();\n    </script>\n</body>\n</html>",
