    {
      "name": "dark-modern",
      "description": "AI-extracted template from reference design",
      "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Design Conversion</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap');\n\n        :root {\n            --bg: #101010;\n            --primary: #00FFC2; /* Green for subheadline and first card border/dot */\n            --secondary: #A000FF; /* Purple for second card border/dot */\n            --accent: #B0FF00; /* Lime green for third card border/dot */\n            --text: #FFFFFF;\n            --text-muted: #A0A0A0;\n            --surface: #1E1E1E;\n            --highlight-text: #A0A0A0; /* For \"entire\" in headline */\n        }\n\n        body {\n            margin: 0;\n            padding: 0;\n            width: 1080px;\n            height: 1080px;\n            overflow: hidden;\n            background: var(--bg);\n            font-family: 'Inter', sans-serif;\n            color: var(--text);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            position: relative; /* For background pattern */\n        }\n\n        /* Background pattern - subtle dots/lines */\n        body::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background-image: radial-gradient(circle, var(--text-muted) 1px, transparent 1px);\n            background-size: 40px 40px;\n            opacity: 0.05; /* Very subtle */\n            z-index: 0;\n        }\n\n        .slide {\n            width: 1080px;\n            height: 1080px;\n            padding: 60px 72px;\n            box-sizing: border-box;\n            display: flex;\n            flex-direction: column;\n            justify-content: flex-start; /* Align content to the top */\n            position: relative;\n            z-index: 1; /* Ensure content is above background pattern */\n        }\n\n        .header-content {\n            margin-top: 60px; /* Push down from top edge of padding */\n            margin-bottom: 120px; /* Space between header and cards */\n        }\n\n        .subheadline {\n            font-size: 14px;\n            font-weight: 700;\n            color: var(--primary);\n            text-transform: uppercase;\n            letter-spacing: 2px;\n            margin-bottom: 20px;\n        }\n\n        .headline {\n            font-size: 72px;\n            font-weight: 700;\n            line-height: 1.1;\n            margin-bottom: 30px;\n        }\n\n        .headline .highlight {\n            color: var(--highlight-text);\n            font-style: normal; /* The design shows different color, not italic */\n        }\n\n        .body-text {\n            font-size: 24px;\n            line-height: 1.5;\n            color: var(--text-muted);\n            max-width: 600px; /* Constrain width as in design */\n        }\n\n        .cards-container {\n            display: flex;\n            gap: 24px; /* Space between cards */\n            margin-bottom: auto; /* Pushes cards up, creating space above footer */\n        }\n\n        .card {\n            flex: 1;\n            background: var(--surface);\n            border-radius: 16px;\n            padding: 32px;\n            display: flex;\n            flex-direction: column;\n            position: relative;\n            overflow: hidden; /* For pseudo-element border */\n        }\n\n        .card::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            height: 8px; /* Border thickness */\n            border-top-left-radius: 16px;\n            border-top-right-radius: 16px;\n        }\n\n        .card.card-1::before { background: var(--primary); }\n        .card.card-2::before { background: var(--secondary); }\n        .card.card-3::before { background: var(--accent); }\n\n        .card-icon {\n            width: 24px; /* Adjusted to match design */\n            height: 24px; /* Adjusted to match design */\n            margin-bottom: 24px;\n            color: var(--text); /* Icon color */\n        }\n\n        .card-title {\n            font-size: 24px;\n            font-weight: 700;\n            line-height: 1.3;\n            margin-bottom: 16px;\n        }\n\n        .card-description {\n            font-size: 16px;\n            line-height: 1.5;\n            color: var(--text-muted);\n            margin-bottom: 24px;\n            flex-grow: 1; /* Push active status to bottom */\n        }\n\n        .card-status {\n            display: flex;\n            align-items: center;\n            font-size: 14px;\n            font-weight: 700;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n        }\n\n        .card-status .dot {\n            width: 8px;\n            height: 8px;\n            border-radius: 50%;\n            margin-right: 8px;\n        }\n\n        .card-1 .card-status .dot { background: var(--primary); }\n        .card-2 .card-status .dot { background: var(--secondary); }\n        .card-3 .card-status .dot { background: var(--accent); }\n\n        .footer {\n            position: absolute;\n            bottom: 40px;\n            left: 72px;\n            right: 72px;\n            display: flex;\n            justify-content: space-between;\n            font-size: 13px;\n            color: var(--text-muted);\n        }\n        .footer .cta-text {\n            display: flex;\n            align-items: center;\n            gap: 8px;\n        }\n        .footer .instagram-label {\n            font-size: 10px;\n            display: block;\n            margin-bottom: 4px;\n        }\n    </style>\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n</head>\n<body>\n    <div class=\"slide\">\n        <div class=\"header-content\">\n            <div class=\"subheadline\">{{subheadline}}</div>\n            <h1 class=\"headline\">\n                {{headline | replace(\"entire\", \"<span class='highlight'>entire</span>\")}}\n            </h1>\n            <p class=\"body-text\">{{body}}</p>\n        </div>\n\n        <div class=\"cards-container\">\n            <div class=\"card card-1\">\n                <i data-lucide=\"file-text\" class=\"card-icon\"></i>\n                <h3 class=\"card-title\">{{card1_title}}</h3>\n                <p class=\"card-description\">{{card1_body}}</p>\n                <div class=\"card-status\">\n                    <span class=\"dot\"></span>\n                    ACTIVE\n                </div>\n            </div>\n            <div class=\"card card-2\">\n                <i data-lucide=\"code\" class=\"card-icon\"></i>\n                <h3 class=\"card-title\">{{card2_title}}</h3>\n                <p class=\"card-description\">{{card2_body}}</p>\n                <div class=\"card-status\">\n                    <span class=\"dot\"></span>\n                    ACTIVE\n                </div>\n            </div>\n            <div class=\"card card-3\">\n                <i data-lucide=\"calendar\" class=\"card-icon\"></i>\n                <h3 class=\"card-title\">{{card3_title}}</h3>\n                <p class=\"card-description\">{{card3_body}}</p>\n                <div class=\"card-status\">\n                    <span class=\"dot\"></span>\n                    ACTIVE\n                </div>\n            </div>\n        </div>\n\n        <div class=\"footer\">\n            <div>\n                <span class=\"instagram-label\">Instagram</span>\n                {{brand_name}}\n            </div>\n            <div class=\"cta-text\">\n                {{cta_text}} <i data-lucide=\"arrow-right\" style=\"width:16px;height:16px\"></i>\n            </div>\n        </div>\n    </div>\n    <script>\n        lucide.createIcons();\n    </script>\n</body>\n</html>",
