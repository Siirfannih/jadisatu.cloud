    {
      "name": "dark-modern",
      "description": "AI-extracted template from reference design",
      "html": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Design Conversion</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Noto+Sans+SC:wght@400;700&family=Oswald:wght@400;700&display=swap');\n\n        :root {\n            --bg: #000000;\n            --primary: #FFFFFF;\n            --text: #FFFFFF;\n            --text-muted: #AAAAAA; /* Not explicitly used in this design */\n            --surface: #000000; /* No distinct surface color in this design */\n        }\n\n        body {\n            margin: 0;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 100vh;\n            background-color: var(--bg); /* Ensure body background is black */\n        }\n\n        .canvas {\n            width: 1080px;\n            height: 1080px;\n            background-color: var(--bg);\n            color: var(--text);\n            font-family: 'Inter', sans-serif;\n            position: relative;\n            overflow: hidden;\n            box-sizing: border-box;\n        }\n\n        header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            padding: 40px 60px;\n        }\n\n        .brand-logo {\n            font-family: 'Oswald', sans-serif;\n            font-weight: 700;\n            font-size: 24px;\n            letter-spacing: 2px;\n            color: var(--primary);\n        }\n\n        .brand-logo span {\n            font-size: 0.7em;\n            vertical-align: super;\n        }\n\n        .chinese-text {\n            font-family: 'Noto Sans SC', sans-serif;\n            font-size: 32px;\n            font-weight: 400;\n            color: var(--primary);\n        }\n\n        main {\n            padding: 0 60px;\n            text-align: center;\n        }\n\n        .headline-area {\n            margin-top: 50px;\n            margin-bottom: 80px;\n        }\n\n        h1 {\n            font-family: 'Oswald', sans-serif;\n            font-size: 48px;\n            font-weight: 700;\n            margin: 0 0 15px 0;\n            line-height: 1.2;\n            color: var(--primary);\n        }\n\n        .subheadline-text {\n            font-size: 20px;\n            line-height: 1.5;\n            max-width: 700px;\n            margin: 0 auto;\n            color: var(--primary);\n        }\n\n        .diagram-container {\n            position: absolute;\n            top: 300px;\n            left: 50%;\n            transform: translateX(-50%);\n            width: 800px; /* SVG width */\n            height: 500px; /* SVG height */\n        }\n\n        .coherence-arc-svg {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n        }\n\n        .label {\n            position: absolute;\n            font-size: 18px;\n            font-weight: 600;\n            white-space: nowrap;\n            color: var(--primary);\n        }\n\n        .inherited-life {\n            top: 60px;\n            left: 0px;\n        }\n\n        .sovereign-life {\n            top: 60px;\n            right: 0px;\n        }\n\n        .visible {\n            top: 200px;\n            left: -80px;\n            font-weight: 400;\n        }\n\n        .hidden {\n            top: 280px;\n            left: -80px;\n            font-weight: 400;\n        }\n\n        .point-wrapper {\n            position: absolute;\n        }\n\n        .point {\n            width: 12px;\n            height: 12px;\n            border-radius: 50%;\n            position: absolute;\n            top: 0;\n            left: 0;\n            transform: translate(-50%, -50%); /* Center the point on its wrapper's coordinates */\n            box-sizing: border-box;\n        }\n\n        .point-hollow {\n            border: 2px solid var(--primary);\n            background: transparent;\n        }\n\n        .point-filled {\n            background: var(--primary);\n            border: 2px solid var(--primary); /* To make it look solid */\n        }\n\n        .label-text {\n            position: absolute;\n            font-size: 16px;\n            white-space: nowrap;\n            color: var(--primary);\n            font-weight: 400;\n        }\n\n        .label-text.rotated {\n            transform-origin: 0 0;\n        }\n\n        .inner-work-label {\n            position: absolute;\n            top: 320px; /* Centered vertically in the shaded area */\n            left: 50%;\n            transform: translateX(-50%);\n            font-family: 'Oswald', sans-serif;\n            font-weight: 700;\n            font-size: 28px;\n            color: var(--primary);\n            white-space: nowrap;\n        }\n\n        footer {\n            position: absolute;\n            bottom: 40px;\n            left: 60px;\n            right: 60px;\n            display: flex;\n            justify-content: space-between;\n            font-size: 14px;\n            line-height: 1.4;\n            color: var(--primary);\n        }\n\n        footer .footer-left,\n        footer .footer-right {\n            text-align: left;\n        }\n\n        footer .footer-right {\n            text-align: right;\n        }\n    </style>\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n</head>\n<body>\n    <div class=\"canvas\">\n        <header>\n            <div class=\"brand-logo\">THE CODE<span style=\"font-size: 0.7em; vertical-align: super;\">X</span></div>\n            <div class=\"chinese-text\">\u624b\u6284\u672c</div>\n        </header>\n\n        <main>\n            <div class=\"headline-area\">\n                <h1>{{headline}}</h1>\n                <p class=\"subheadline-text\">{{body}}</p>\n            </div>\n\n            <div class=\"diagram-container\">\n                <div class=\"label inherited-life\">The Inherited Life</div>\n                <div class=\"label sovereign-life\">The Sovereign Life</div>\n                <div class=\"label visible\">Visible</div>\n                <div class=\"label hidden\">Hidden</div>\n\n                <svg class=\"coherence-arc-svg\" width=\"800\" height=\"500\" viewBox=\"0 0 800 500\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <defs>\n                        <pattern id=\"diagonalHatch\" patternUnits=\"userSpaceOnUse\" width=\"10\" height=\"10\" patternTransform=\"rotate(45)\">\n                            <line x1=\"0\" y1=\"0\" x2=\"0\" y2=\"10\" stroke=\"white\" stroke-width=\"1.5\"/>\n                        </pattern>\n                    </defs>\n                    <!-- Main arc path -->\n                    <path id=\"mainArcPath\" d=\"M 100 100 C 200 450, 600 450, 700 100\" stroke=\"white\" stroke-width=\"2\" fill=\"none\"/>\n                    <!-- Dashed line -->\n                    <line x1=\"100\" y1=\"250\" x2=\"700\" y2=\"250\" stroke=\"white\" stroke-dasharray=\"8 8\" stroke-width=\"1\"/>\n                    <!-- Shaded area path -->\n                    <path d=\"M 180 250 C 250 380, 550 380, 620 250 L 180 250 Z\" fill=\"url(#diagonalHatch)\" stroke=\"white\" stroke-width=\"2\"/>\n                </svg>\n\n                <!-- Points and labels on the arc -->\n                <!-- Hollow start point of the arc -->\n                <div class=\"point point-hollow\" style=\"top: 100px; left: 100px;\"></div>\n                <!-- Hollow end point of the arc -->\n                <div class=\"point point-hollow\" style=\"top: 100px; left: 700px;\"></div>\n\n                <!-- Dissonance -->\n                <div class=\"point-wrapper\" style=\"top: 140px; left: 150px;\">\n                    <div class=\"point point-filled\"></div>\n                    <div class=\"label-text rotated\" style=\"transform: rotate(-30deg); top: 10px; left: 20px;\">Dissonance</div>\n                </div>\n                <!-- Rupture -->\n                <div class=\"point-wrapper\" style=\"top: 240px; left: 240px;\">\n                    <div class=\"point point-filled\"></div>\n                    <div class=\"label-text\" style=\"top: -20px; left: 20px;\">Rupture</div>\n                </div>\n                <!-- Dissolution -->\n                <div class=\"point-wrapper\" style=\"top: 280px; left: 280px;\">\n                    <div class=\"point point-filled\"></div>\n                    <div class=\"label-text rotated\" style=\"transform: rotate(-30deg); top: 10px; left: -80px;\">Dissolution</div>\n                </div>\n                <!-- Rebellion -->\n                <div class=\"point-wrapper\" style=\"top: 360px; left: 300px;\">\n                    <div class=\"point point-filled\"></div>\n                    <div class=\"label-text\" style=\"top: 20px; left: -20px;\">Rebellion</div>\n                </div>\n                <!-- Regret -->\n                <div class=\"point-wrapper\" style=\"top: 380px; left: 390px;\">\n                    <div class=\"point point-filled\"></div>\n                    <div class=\"label-text\" style=\"top: 20px; left: 20px;\">Regret</div>\n                </div>\n                <!-- Regulation -->\n                <div class=\"point-wrapper\" style=\"top: 360px; left: 490px;\">\n                    <div class=\"point point-filled\"></div>\n                    <div class=\"label-text\" style=\"top: 20px; left: 20px;\">Regulation</div>\n                </div>\n                <!-- Integration -->\n                <div class=\"point-wrapper\" style=\"top: 280px; left: 510px;\">\n                    <div class=\"point point-filled\"></div>\n                    <div class=\"label-text rotated\" style=\"transform: rotate(30deg); top: 10px; left: 20px;\">Integration</div>\n                </div>\n                <!-- Recalibration -->\n                <div class=\"point-wrapper\" style=\"top: 240px; left: 560px;\">\n                    <div class=\"point point-filled\"></div>\n                    <div class=\"label-text\" style=\"top: 20px; left: 20px;\">Recalibration</div>\n                </div>\n                <!-- Rebirth -->\n                <div class=\"point-wrapper\" style=\"top: 200px; left: 590px;\">\n                    <div class=\"point point-filled\"></div>\n                    <div class=\"label-text\" style=\"top: -20px; left: 20px;\">Rebirth</div>\n                </div>\n                <!-- Emergence -->\n                <div class=\"point-wrapper\" style=\"top: 140px; left: 640px;\">\n                    <div class=\"point point-filled\"></div>\n                    <div class=\"label-text rotated\" style=\"transform: rotate(30deg); top: 10px; left: -80px;\">Emergence</div>\n                </div>\n\n                <!-- Inner Work label -->\n                <div class=\"inner-work-label\">\n                    <h3>Inner Work</h3>\n                </div>\n            </div>\n        </main>\n\n        <footer>\n            <div class=\"footer-left\">Alan Hong<br>@thealanhong</div>\n            <div class=\"footer-right\">\u00a9{{brand_name}} 2026<br>www.thecodexx.com</div>\n        </footer>\n    </div>\n    <script>\n        lucide.createIcons();\n    </script>\n</body>\n</html>",
