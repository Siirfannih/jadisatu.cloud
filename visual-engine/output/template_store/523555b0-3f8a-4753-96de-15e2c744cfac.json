    {
      "name": "dark-editorial",
      "description": "AI-extracted template from reference design",
      "html": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Design Conversion</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Lora:wght@400&family=Zhi+Mang+Xing&display=swap');\n\n        :root {\n            --bg: #000000;\n            --text: #E0E0E0;\n            --text-muted: #A0A0A0;\n            /* Placeholder colors as per requirements, not explicitly used beyond text/bg in this design */\n            --primary: #E0E0E0;\n            --secondary: #A0A0A0;\n            --accent: #E0E0E0;\n            --surface: #000000;\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Inter', sans-serif;\n            color: var(--text);\n            background-color: var(--bg);\n            width: 1080px;\n            height: 1080px;\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between; /* Distribute space between header, main, footer */\n            align-items: stretch; /* Allow children to fill width */\n        }\n\n        .header, .footer {\n            display: flex;\n            justify-content: space-between;\n            align-items: flex-start; /* For header, align items to the top */\n            padding: 80px 100px 0 100px; /* Top padding, left/right padding */\n            font-size: 16px;\n            color: var(--text-muted);\n        }\n\n        .footer {\n            align-items: flex-end; /* For footer, align items to the bottom */\n            padding: 0 100px 80px 100px; /* Bottom padding, left/right padding */\n        }\n\n        .header .brand-name {\n            font-weight: 400;\n            letter-spacing: 0.1em;\n            text-transform: uppercase;\n            color: var(--text-muted);\n        }\n\n        .header .decorative-text {\n            font-family: 'Zhi Mang Xing', cursive;\n            font-size: 48px;\n            line-height: 1;\n            color: var(--text);\n        }\n\n        .main-content {\n            flex-grow: 1; /* Allow main content to take available space */\n            display: flex;\n            flex-direction: column;\n            justify-content: center; /* Center content vertically within its space */\n            padding: 0 100px; /* Left/right padding */\n            max-width: 880px; /* 1080px - 100px (left) - 100px (right) */\n            margin: 0 auto; /* Center horizontally */\n        }\n\n        .headline {\n            font-family: 'Inter', sans-serif;\n            font-size: 48px;\n            font-weight: 700;\n            text-transform: uppercase;\n            letter-spacing: 0.05em;\n            margin-bottom: 40px; /* Spacing between headline and body */\n            line-height: 1.2;\n            color: var(--text);\n        }\n\n        .body-text {\n            font-family: 'Lora', serif;\n            font-size: 32px;\n            line-height: 1.5;\n            color: var(--text);\n            max-width: 880px; /* Ensure text doesn't overflow */\n        }\n\n        .footer .author-info {\n            font-size: 14px;\n            line-height: 1.4;\n            color: var(--text-muted);\n        }\n\n        .footer .copyright-info {\n            font-size: 14px;\n            line-height: 1.4;\n            text-align: right;\n            color: var(--text-muted);\n        }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <div class=\"brand-name\">{{brand_name}}</div>\n        <div class=\"decorative-text\">\u624b\u6284\u672c</div>\n    </div>\n\n    <div class=\"main-content\">\n        <h1 class=\"headline\">{{headline}}</h1>\n        <p class=\"body-text\">{{body}}</p>\n    </div>\n\n    <div class=\"footer\">\n        <div class=\"author-info\">\n            {{subheadline}}\n        </div>\n        <div class=\"copyright-info\">\n            &copy; {{brand_name}} 2026<br>\n            www.thecodexx.com\n        </div>\n    </div>\n\n    <!-- Lucide icons are not explicitly used in this specific design, but the script is included as per general requirements. -->\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <script>lucide.createIcons();</script>\n</body>\n</html>",
