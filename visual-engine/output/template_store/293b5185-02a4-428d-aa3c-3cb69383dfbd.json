    {
      "name": "dark-editorial",
      "description": "AI-extracted template from reference design",
      "html": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Design Conversion</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;700&family=Ma+Shan+Zheng&display=swap\" rel=\"stylesheet\">\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;700&family=Ma+Shan+Zheng&display=swap');\n\n        :root {\n            --bg: #000000;\n            --primary: #f0f0f0;\n            --secondary: #888888;\n            --accent: #f0f0f0; /* Not explicitly used, but kept for consistency */\n            --text: var(--primary);\n            --text-muted: var(--secondary);\n            --surface: var(--bg); /* No distinct surface in this design */\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Inter', sans-serif; /* Default sans-serif font */\n            color: var(--text);\n            background-color: var(--bg);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 100vh; /* Ensure body takes full viewport height for centering */\n        }\n\n        .canvas {\n            width: 1080px;\n            height: 1080px;\n            background-color: var(--bg);\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between; /* Pushes header to top, footer to bottom */\n            align-items: center; /* Centers content horizontally if not full width */\n            padding: 40px; /* Overall padding for the canvas */\n            box-sizing: border-box; /* Include padding in width/height */\n        }\n\n        header {\n            width: 100%;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            /* No specific padding-bottom here, let main's padding handle vertical spacing */\n        }\n\n        .brand-left {\n            font-family: 'Inter', sans-serif;\n            font-size: 18px;\n            font-weight: 400;\n            letter-spacing: 2px;\n            text-transform: uppercase;\n            color: var(--text-muted);\n        }\n\n        .brand-right {\n            font-family: 'Ma Shan Zheng', cursive; /* Using a script font for Chinese characters */\n            font-size: 48px; /* Larger size for the script */\n            color: var(--text-muted);\n            line-height: 1; /* Adjust line height for script font */\n            transform: translateY(-5px); /* Slight adjustment to align with brand-left visually */\n        }\n\n        main {\n            flex-grow: 1; /* Takes up remaining space */\n            display: flex;\n            justify-content: center;\n            align-items: center; /* Centers content vertically within main */\n            width: 100%;\n            padding-bottom: 80px; /* Shift text block upwards by adding more bottom padding */\n        }\n\n        .body-text {\n            font-family: 'Lora', serif;\n            font-size: 48px;\n            line-height: 1.4;\n            font-style: italic;\n            color: var(--text);\n            text-align: left; /* Text is left-aligned within its block */\n            max-width: 750px; /* Approximate width for the text block */\n            margin: 0; /* Reset default paragraph margin */\n        }\n\n        footer {\n            width: 100%;\n            display: flex;\n            justify-content: space-between;\n            align-items: flex-end; /* Align text to the bottom */\n            /* No specific padding-top here, let main's padding handle vertical spacing */\n            font-family: 'Inter', sans-serif;\n            font-size: 14px;\n            color: var(--text-muted);\n            line-height: 1.4;\n        }\n\n        .footer-left p, .footer-right p {\n            margin: 0;\n            padding: 0;\n        }\n\n        .footer-right {\n            text-align: right;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"canvas\">\n        <header>\n            <div class=\"brand-left\">{{brand_name}}</div>\n            <div class=\"brand-right\">{{brand_name}}</div> <!-- For Chinese characters -->\n        </header>\n\n        <main>\n            <p class=\"body-text\">{{body}}</p>\n        </main>\n\n        <footer>\n            <div class=\"footer-left\">\n                <p>Alan Hong</p>\n                <p>@thealanhong</p>\n            </div>\n            <div class=\"footer-right\">\n                <p>&copy; The Codexx 2026</p>\n                <p>www.thecodexx.com</p>\n            </div>\n        </footer>\n    </div>\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <script>lucide.createIcons()</script>\n</body>\n</html>",
