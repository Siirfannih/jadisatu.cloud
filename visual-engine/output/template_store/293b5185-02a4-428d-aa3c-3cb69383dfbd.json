    {
      "name": "dark-modern",
      "description": "AI-extracted template from reference design",
      "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Design Conversion</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700&family=Montserrat:wght@700&display=swap');\n\n        :root {\n            --bg: #000000;\n            --primary: #FFFFFF;\n            --text: #FFFFFF;\n            --text-muted: #AAAAAA;\n            --surface: #000000; /* Not explicitly used as a card surface in this design */\n        }\n\n        body {\n            margin: 0;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 100vh;\n            background-color: var(--bg);\n            font-family: 'Inter', sans-serif;\n            color: var(--text);\n            overflow: hidden; /* Prevent scrollbars on fixed canvas */\n            -webkit-font-smoothing: antialiased;\n            -moz-osx-font-smoothing: grayscale;\n        }\n\n        #canvas {\n            width: 1080px;\n            height: 1080px;\n            background-color: var(--bg);\n            position: relative;\n            display: flex;\n            flex-direction: column;\n            box-sizing: border-box;\n            padding: 60px 80px; /* Overall padding for the canvas */\n        }\n\n        .header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 80px; /* Space below header */\n        }\n\n        .logo {\n            font-family: 'Inter', sans-serif;\n            font-weight: 700;\n            font-size: 18px;\n            letter-spacing: 2px;\n            color: var(--text);\n            display: flex;\n            align-items: center;\n        }\n\n        .logo span:first-child {\n            margin-right: 4px;\n        }\n\n        .chinese-text {\n            font-size: 48px; /* Approximate size for visual match */\n            font-family: serif; /* Placeholder font for calligraphy */\n            color: var(--text);\n            line-height: 1;\n        }\n\n        .main-content {\n            flex-grow: 1;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            text-align: center;\n            position: relative; /* For positioning the diagram */\n        }\n\n        .headline {\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 700;\n            font-size: 48px;\n            line-height: 1.2;\n            margin-bottom: 16px;\n        }\n\n        .subheadline {\n            font-family: 'Inter', sans-serif;\n            font-weight: 400;\n            font-size: 20px;\n            line-height: 1.5;\n            color: var(--text-muted);\n            max-width: 600px; /* Constrain width as in design */\n            margin-bottom: 80px; /* Space before diagram */\n        }\n\n        .diagram-container {\n            position: relative;\n            width: 800px; /* Width of the SVG viewBox */\n            height: 500px; /* Height of the SVG viewBox */\n            margin-top: 40px; /* Space from subheadline */\n        }\n\n        .diagram-svg {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            overflow: visible; /* Allow path strokes to extend if needed */\n        }\n\n        .diagram-svg .arc-path {\n            fill: none;\n            stroke: var(--primary);\n            stroke-width: 2px;\n        }\n\n        .diagram-svg .dashed-line {\n            stroke: var(--primary);\n            stroke-width: 1px;\n            stroke-dasharray: 6 6;\n        }\n\n        .diagram-svg .hatched-fill {\n            fill: url(#hatchedPattern);\n        }\n\n        /* Labels and dots */\n        .diagram-label {\n            position: absolute;\n            font-family: 'Inter', sans-serif;\n            font-weight: 400;\n            font-size: 16px;\n            color: var(--text);\n            white-space: nowrap;\n            pointer-events: none; /* Prevent text from interfering with interactions */\n        }\n\n        .diagram-label.bold {\n            font-weight: 700;\n            font-size: 20px;\n        }\n\n        .diagram-dot {\n            position: absolute;\n            width: 12px;\n            height: 12px;\n            background-color: var(--primary);\n            border-radius: 50%;\n            transform: translate(-50%, -50%); /* Center dot on its position */\n            pointer-events: none;\n        }\n\n        .diagram-dot.hollow {\n            background-color: transparent;\n            border: 2px solid var(--primary);\n        }\n\n        .footer {\n            display: flex;\n            justify-content: space-between;\n            align-items: flex-end;\n            margin-top: auto; /* Push to bottom */\n            padding-top: 40px; /* Space from diagram */\n            font-family: 'Inter', sans-serif;\n            font-weight: 300;\n            font-size: 14px;\n            color: var(--text-muted);\n        }\n\n        .footer-left {\n            text-align: left;\n        }\n\n        .footer-right {\n            text-align: right;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"canvas\">\n        <div class=\"header\">\n            <div class=\"logo\">\n                <span>THE</span><span>CODEX</span>\n            </div>\n            <div class=\"chinese-text\">\u624b\u6284\u672c</div>\n        </div>\n\n        <div class=\"main-content\">\n            <h1 class=\"headline\">{{headline}}</h1>\n            <p class=\"subheadline\">{{subheadline}}</p>\n\n            <div class=\"diagram-container\">\n                <svg class=\"diagram-svg\" viewBox=\"0 0 800 500\">\n                    <defs>\n                        <pattern id=\"hatchedPattern\" patternUnits=\"userSpaceOnUse\" width=\"10\" height=\"10\" patternTransform=\"rotate(45)\">\n                            <line x1=\"0\" y1=\"0\" x2=\"0\" y2=\"10\" stroke=\"white\" stroke-width=\"1.5\"/>\n                        </pattern>\n                    </defs>\n\n                    <!-- Main Arc Path (Approximation based on visual flow) -->\n                    <path class=\"arc-path\" d=\"M 100 100 C 180 50, 250 150, 280 250 S 350 350, 400 380 S 450 350, 520 250 S 550 150, 620 50, 700 100\" />\n\n                    <!-- Hatched Area Path (Bounded by dashed line and arc) -->\n                    <path class=\"hatched-fill\" d=\"M 280 250 C 300 300, 350 350, 400 380 C 450 350, 500 300, 520 250 L 520 250 L 280 250 Z\" />\n\n                    <!-- Dashed Line -->\n                    <line class=\"dashed-line\" x1=\"0\" y1=\"250\" x2=\"800\" y2=\"250\" />\n                </svg>\n\n                <!-- Labels and Dots - positioned relative to diagram-container -->\n                <!-- The Inherited Life -->\n                <div class=\"diagram-label bold\" style=\"top: 60px; left: 80px;\">The Inherited Life</div>\n                <div class=\"diagram-dot hollow\" style=\"top: 100px; left: 100px;\"></div>\n\n                <!-- Dissonance -->\n                <div class=\"diagram-label\" style=\"top: 180px; left: 180px; transform: rotate(-30deg);\">Dissonance</div>\n                <div class=\"diagram-dot\" style=\"top: 200px; left: 220px;\"></div>\n\n                <!-- Rupture -->\n                <div class=\"diagram-label\" style=\"top: 200px; left: 300px;\">Rupture</div>\n                <div class=\"diagram-dot\" style=\"top: 230px; left: 330px;\"></div>\n\n                <!-- Visible/Hidden -->\n                <div class=\"diagram-label\" style=\"top: 220px; left: -50px; text-align: right; width: 100px;\">Visible</div>\n                <div class=\"diagram-label\" style=\"top: 280px; left: -50px; text-align: right; width: 100px;\">Hidden</div>\n\n                <!-- Dissolution -->\n                <div class=\"diagram-label\" style=\"top: 300px; left: 250px; transform: rotate(-30deg);\">Dissolution</div>\n                <div class=\"diagram-dot\" style=\"top: 350px; left: 280px;\"></div>\n\n                <!-- Rebellion -->\n                <div class=\"diagram-label\" style=\"top: 450px; left: 300px;\">Rebellion</div>\n                <div class=\"diagram-dot\" style=\"top: 400px; left: 320px;\"></div>\n\n                <!-- Regret -->\n                <div class=\"diagram-label\" style=\"top: 450px; left: 400px;\">Regret</div>\n                <div class=\"diagram-dot\" style=\"top: 400px; left: 420px;\"></div>\n\n                <!-- Inner Work -->\n                <div class=\"diagram-label bold\" style=\"top: 300px; left: 50%; transform: translateX(-50%);\">Inner Work</div>\n\n                <!-- Regulation -->\n                <div class=\"diagram-label\" style=\"top: 450px; left: 500px;\">Regulation</div>\n                <div class=\"diagram-dot\" style=\"top: 400px; left: 520px;\"></div>\n\n                <!-- Integration -->\n                <div class=\"diagram-label\" style=\"top: 300px; left: 550px; transform: rotate(30deg);\">Integration</div>\n                <div class=\"diagram-dot\" style=\"top: 350px; left: 520px;\"></div>\n\n                <!-- Recalibration -->\n                <div class=\"diagram-label\" style=\"top: 270px; left: 580px;\">Recalibration</div>\n                <div class=\"diagram-dot\" style=\"top: 230px; left: 570px;\"></div>\n\n                <!-- Rebirth -->\n                <div class=\"diagram-label\" style=\"top: 200px; left: 620px;\">Rebirth</div>\n                <div class=\"diagram-dot\" style=\"top: 200px; left: 590px;\"></div>\n\n                <!-- Emergence -->\n                <div class=\"diagram-label\" style=\"top: 180px; left: 580px; transform: rotate(30deg);\">Emergence</div>\n                <div class=\"diagram-dot\" style=\"top: 100px; left: 680px;\"></div>\n\n                <!-- The Sovereign Life -->\n                <div class=\"diagram-label bold\" style=\"top: 60px; right: 80px;\">The Sovereign Life</div>\n                <div class=\"diagram-dot hollow\" style=\"top: 100px; right: 100px;\"></div>\n\n            </div>\n        </div>\n\n        <div class=\"footer\">\n            <div class=\"footer-left\">\n                Alan Hong<br>\n                @thealanhong\n            </div>\n            <div class=\"footer-right\">\n                &copy;The Codexx 2026<br>\n                www.thecodexx.com\n            </div>\n        </div>\n    </div>\n</body>\n</html>",
