      "html": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Design Conversion</title>\n  <link rel=\"icon\" href=\"data:,\" />\n  <style>\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Montserrat:ital,wght@0,700;1,700&display=swap');\n\n    :root {\n      --bg: #F5F4F0;\n      --primary: #34D399; /* Green accent */\n      --secondary: #1A1A1A; /* Dark text, Agent card */\n      --accent: #BDBDBD; /* Grey cards */\n      --text: #1A1A1A;\n      --text-muted: #888888;\n      --light-grey-bg-pattern: #E0E0E0; /* For the subtle background lines/dots */\n    }\n\n    html, body {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n      font-family: 'Inter', sans-serif;\n      color: var(--text);\n      -webkit-font-smoothing: antialiased;\n      -moz-osx-font-smoothing: grayscale;\n    }\n\n    .container {\n      width: 1080px;\n      height: 1080px;\n      background-color: var(--bg);\n      display: flex;\n      flex-direction: column;\n      justify-content: space-between;\n      align-items: center; /* Centers content-wrapper and footer horizontally */\n      position: relative; /* For absolute positioning of background elements */\n      overflow: hidden; /* Hide overflow from background elements */\n    }\n\n    .content-wrapper {\n      width: 800px; /* Fixed width for main content block */\n      display: flex;\n      flex-direction: column;\n      align-items: flex-start; /* Align text and cards to the left within this block */\n      padding-top: 120px; /* Top padding for the main content block */\n      box-sizing: border-box;\n    }\n\n    .headline-section {\n      width: 100%;\n      margin-bottom: 80px; /* Space between headline and cards */\n      text-align: left;\n    }\n\n    h1 {\n      font-family: 'Montserrat', sans-serif;\n      font-weight: 700;\n      font-size: 72px;\n      line-height: 1.2;\n      margin: 0;\n      padding: 0;\n      color: var(--text);\n      width: 600px; /* Constrain width to match line breaks in design */\n    }\n\n    h1 .italic-text {\n      font-style: italic;\n    }\n\n    h1 .highlight-text {\n      color: var(--primary);\n    }\n\n    .statistic {\n      margin-top: 40px;\n      text-align: left;\n    }\n\n    .statistic .number {\n      font-family: 'Montserrat', sans-serif;\n      font-weight: 700;\n      font-size: 120px;\n      line-height: 1;\n      color: var(--text);\n      display: block;\n    }\n\n    .statistic .underline {\n      width: 100px; /* Length of the underline */\n      height: 4px;\n      background-color: var(--primary);\n      margin-top: 10px;\n      margin-bottom: 10px;\n    }\n\n    .statistic .sub-statistic {\n      font-family: 'Inter', sans-serif;\n      font-weight: 400;\n      font-size: 20px;\n      color: var(--text-muted);\n      margin: 0;\n    }\n\n    .card-grid {\n      display: flex;\n      gap: 24px; /* Spacing between cards */\n      margin-left: -100px; /* Shift cards further left relative to content-wrapper */\n      justify-content: flex-start; /* Align cards to the left within their shifted container */\n    }\n\n    .card {\n      width: 160px; /* Card width */\n      height: 160px; /* Card height */\n      border-radius: 20px; /* Rounded corners */\n      display: flex;\n      flex-direction: column;\n      justify-content: center;\n      align-items: center;\n      box-shadow: 8px 8px 16px rgba(0,0,0,0.08), -8px -8px 16px rgba(255,255,255,0.7); /* Neumorphic shadow */\n      transition: transform 0.2s ease-in-out;\n      cursor: pointer;\n    }\n\n    .card:hover {\n      transform: translateY(-5px);\n    }\n\n    .card i {\n      width: 48px;\n      height: 48px;\n      margin-bottom: 10px;\n    }\n\n    .card span {\n      font-family: 'Inter', sans-serif;\n      font-weight: 500;\n      font-size: 14px;\n      text-transform: uppercase;\n      letter-spacing: 0.5px;\n    }\n\n    .card-grey {\n      background-color: var(--accent);\n      color: var(--text); /* Icons and text color */\n    }\n\n    .card-dark {\n      background-color: var(--secondary);\n      color: var(--primary); /* Icons and text color */\n    }\n\n    .card-green {\n      background-color: var(--primary);\n      color: var(--secondary); /* Icons and text color */\n    }\n\n    .footer {\n      width: 100%; /* Full width of the container */\n      display: flex;\n      justify-content: space-between;\n      padding: 0 80px 60px 80px; /* Footer has specific padding */\n      box-sizing: border-box;\n      font-family: 'Inter', sans-serif;\n      font-size: 16px;\n      color: var(--text-muted);\n    }\n\n    .footer p {\n      margin: 0;\n    }\n\n    .cta-info {\n      display: flex;\n      align-items: center;\n    }\n\n    /* Decorative Background Elements */\n    /* These are simplified representations of the background pattern */\n    .bg-pattern-dot {\n      position: absolute;\n      width: 8px;\n      height: 8px;\n      background-color: var(--light-grey-bg-pattern);\n      border-radius: 50%;\n      opacity: 0.6;\n    }\n\n    .bg-pattern-line {\n      position: absolute;\n      height: 2px;\n      background-color: var(--light-grey-bg-pattern);\n      opacity: 0.6;\n      transform-origin: 0 0;\n    }\n\n    /* Specific placements for dots and lines */\n    .dot-top-left { top: 100px; left: 100px; }\n    .line-top-left-1 {\n      top: 104px; left: 108px;\n      width: 120px;\n      transform: rotate(15deg);\n    }\n    .dot-top-right { top: 80px; right: 100px; }\n    .line-top-right-1 {\n      top: 84px; right: 108px;\n      width: 100px;\n      transform: rotate(-20deg);\n      transform-origin: 100% 0; /* Rotate from right end */\n    }\n    .line-top-right-2 {\n      top: 84px; right: 108px;\n      width: 150px;\n      transform: rotate(10deg);\n      transform-origin: 100% 0;\n    }\n    .dot-mid-right { top: 400px; right: 120px; }\n    .line-mid-right-1 {\n      top: 404px; right: 128px;\n      width: 100px;\n      transform: rotate(-30deg);\n      transform-origin: 100% 0;\n    }\n    .dot-bottom-left { bottom: 180px; left: 100px; }\n    .line-bottom-left-1 {\n      bottom: 184px; left: 108px;\n      width: 120px;\n      transform: rotate(-10deg);\n    }\n    .dot-bottom-right { bottom: 120px; right: 100px; }\n    .line-bottom-right-1 {\n      bottom: 124px; right: 108px;\n      width: 100px;\n      transform: rotate(20deg);\n      transform-origin: 100% 0;\n    }\n  </style>\n  <script src=\"https://unpkg.com/lucide@latest\"></script>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"content-wrapper\">\n      <div class=\"headline-section\">\n        <!-- Assuming {{headline}} content will include <span> tags for styling, e.g., \"The first <span class='italic-text'>real AI</span> employee is <span class='highlight-text'>here.</span>\" -->\n        <h1>{{headline}}</h1>\n        <div class=\"statistic\">\n          <span class=\"number\">{{body}}</span>\n          <div class=\"underline\"></div>\n          <p class=\"sub-statistic\">{{subheadline}}</p>\n        </div>\n      </div>\n\n      <div class=\"card-grid\">\n        <div class=\"card card-grey\">\n          <div class=\"icon-area\"><!-- ICON:mail --><i data-lucide=\"mail\" style=\"width:48px;height:48px\"></i></div>\n          <span>EMAIL</span>\n        </div>\n        <div class=\"card card-dark\">\n          <div class=\"icon-area\"><!-- ICON:bot --><i data-lucide=\"bot\" style=\"width:48px;height:48px\"></i></div>\n          <span>AGENT</span>\n        </div>\n        <div class=\"card card-green\">\n          <div class=\"icon-area\"><!-- ICON:calendar-days --><i data-lucide=\"calendar-days\" style=\"width:48px;height:48px\"></i></div>\n          <span>SCHEDULE</span>\n        </div>\n        <div class=\"card card-grey\">\n          <div class=\"icon-area\"><!-- ICON:code --><i data-lucide=\"code\" style=\"width:48px;height:48px\"></i></div>\n          <span>CODE</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"footer\">\n      <p class=\"brand-info\">{{brand_name}}</p>\n      <p class=\"cta-info\">{{cta_text}} <i data-lucide=\"arrow-right\" style=\"width:16px;height:16px;vertical-align:middle;margin-left:4px;\"></i></p>\n    </div>\n\n    <!-- Decorative background elements -->\n    <div class=\"bg-pattern-dot dot-top-left\"></div>\n    <div class=\"bg-pattern-line line-top-left-1\"></div>\n    <div class=\"bg-pattern-dot dot-top-right\"></div>\n    <div class=\"bg-pattern-line line-top-right-1\"></div>\n    <div class=\"bg-pattern-line line-top-right-2\"></div>\n    <div class=\"bg-pattern-dot dot-mid-right\"></div>\n    <div class=\"bg-pattern-line line-mid-right-1\"></div>\n    <div class=\"bg-pattern-dot dot-bottom-left\"></div>\n    <div class=\"bg-pattern-line line-bottom-left-1\"></div>\n    <div class=\"bg-pattern-dot dot-bottom-right\"></div>\n    <div class=\"bg-pattern-line line-bottom-right-1\"></div>\n  </div>\n\n  <script>\n    lucide.createIcons();\n  </script>\n</body>\n</html>",
