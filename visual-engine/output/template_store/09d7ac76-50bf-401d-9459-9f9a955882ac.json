      "html": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Design Conversion</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,700;0,800;0,900;1,400&display=swap');\n\n        :root {\n            --bg: #EBEAE4;\n            --primary: #000000; /* For the main agent card background */\n            --secondary: #2ECC71; /* Green for schedule card background and highlight */\n            --accent: #2ECC71; /* Highlight color, same as secondary */\n            --text: #333333;\n            --text-muted: #8A8A8A; /* Lighter/muted text color */\n            --surface: #B0B0B0; /* Grey card background color */\n        }\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 1080px;\n            height: 1080px;\n            overflow: hidden;\n            background: var(--bg);\n            font-family: 'Inter', sans-serif;\n            color: var(--text);\n            box-sizing: border-box;\n        }\n\n        .slide {\n            width: 1080px;\n            height: 1080px;\n            padding: 60px 72px;\n            box-sizing: border-box;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            position: relative;\n            z-index: 1; /* Ensure content is above background patterns */\n        }\n\n        /* Background pattern */\n        .background-pattern {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            z-index: 0;\n        }\n        .pattern-element {\n            position: absolute;\n            height: 0; /* Make it a line */\n            border-top: 1px solid var(--text-muted);\n            opacity: 0.2;\n            transform-origin: left center;\n        }\n\n        /* Specific pattern lines to mimic the design */\n        /* Top right */\n        .pattern-element:nth-child(1) { top: 80px; left: 700px; transform: rotate(30deg); width: 100px; }\n        .pattern-element:nth-child(2) { top: 120px; left: 780px; transform: rotate(-15deg); width: 80px; }\n        .pattern-element:nth-child(3) { top: 100px; left: 850px; transform: rotate(45deg); width: 60px; }\n        .pattern-element:nth-child(4) { top: 150px; left: 900px; transform: rotate(-30deg); width: 90px; }\n        .pattern-element:nth-child(5) { top: 200px; left: 950px; transform: rotate(20deg); width: 70px; }\n\n        /* Bottom left */\n        .pattern-element:nth-child(6) { bottom: 100px; left: 100px; transform: rotate(-20deg); width: 90px; }\n        .pattern-element:nth-child(7) { bottom: 150px; left: 180px; transform: rotate(35deg); width: 70px; }\n        .pattern-element:nth-child(8) { bottom: 120px; left: 250px; transform: rotate(-10deg); width: 80px; }\n        .pattern-element:nth-child(9) { bottom: 180px; left: 320px; transform: rotate(50deg); width: 60px; }\n        .pattern-element:nth-child(10) { bottom: 220px; left: 380px; transform: rotate(-25deg); width: 100px; }\n\n        /* Main content styling */\n        .headline-group {\n            margin-bottom: 40px;\n        }\n\n        h1 {\n            font-size: 88px;\n            font-weight: 900;\n            line-height: 1.1;\n            margin: 0;\n            padding: 0;\n        }\n\n        .highlight {\n            color: var(--accent);\n            font-style: italic;\n        }\n\n        .number-display {\n            font-size: 120px;\n            font-weight: 900;\n            margin-top: 40px;\n            margin-bottom: 10px;\n            position: relative;\n            display: inline-block; /* To contain the underline */\n        }\n\n        .number-display::after {\n            content: '';\n            position: absolute;\n            left: 0;\n            bottom: 10px; /* Position relative to text baseline */\n            width: 100px; /* Length of the underline */\n            height: 4px;\n            background: var(--text-muted);\n            opacity: 0.5;\n        }\n\n        .body-text {\n            font-size: 24px;\n            font-weight: 400;\n            color: var(--text-muted);\n            margin-top: 0;\n            margin-bottom: 100px; /* Space before cards */\n        }\n\n        .card-container {\n            display: flex;\n            gap: 24px; /* Spacing between cards */\n            justify-content: center;\n            align-items: center;\n            margin-top: auto; /* Push cards towards the bottom, above footer */\n            margin-bottom: 150px; /* Space from bottom */\n        }\n\n        .card-3d {\n            background: var(--surface);\n            border-radius: 16px;\n            box-shadow: 0 4px 0 rgba(0,0,0,0.15), 0 8px 20px rgba(0,0,0,0.1);\n            transform: perspective(500px) rotateX(2deg);\n            width: 140px; /* Card size */\n            height: 140px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            color: var(--text);\n            font-size: 14px;\n            font-weight: 700;\n            text-transform: uppercase;\n            transition: transform 0.2s ease, box-shadow 0.2s ease;\n            cursor: pointer;\n        }\n\n        .card-3d:hover {\n            transform: perspective(500px) rotateX(0deg) translateY(-5px);\n            box-shadow: 0 8px 0 rgba(0,0,0,0.15), 0 12px 30px rgba(0,0,0,0.1);\n        }\n\n        .card-3d i {\n            margin-bottom: 8px;\n            color: var(--text); /* Default icon color */\n        }\n\n        .card-3d.primary-card {\n            background: var(--primary);\n            color: #FFFFFF;\n            transform: perspective(500px) rotateX(0deg) translateY(-10px); /* Slightly more prominent and flat */\n            box-shadow: 0 6px 0 rgba(0,0,0,0.2), 0 12px 30px rgba(0,0,0,0.15);\n        }\n\n        .card-3d.primary-card i {\n            color: var(--secondary); /* Green icon for primary card */\n        }\n\n        .card-3d.secondary-card {\n            background: var(--secondary);\n            color: #FFFFFF;\n        }\n\n        .card-3d.secondary-card i {\n            color: #FFFFFF; /* White icon for secondary card */\n        }\n\n        .footer {\n            position: absolute;\n            bottom: 40px;\n            left: 72px;\n            right: 72px;\n            display: flex;\n            justify-content: space-between;\n            font-size: 16px;\n            color: var(--text-muted);\n            font-weight: 400;\n        }\n\n        .footer .swipe-text {\n            display: flex;\n            align-items: center;\n            gap: 8px;\n        }\n        .footer .swipe-text i {\n            color: var(--text-muted);\n            width: 16px;\n            height: 16px;\n        }\n\n        /* Lucide icon styling */\n        .lucide {\n            stroke-width: 1.5; /* Make icons thinner */\n        }\n\n    </style>\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n</head>\n<body>\n    <div class=\"background-pattern\">\n        <div class=\"pattern-element\"></div>\n        <div class=\"pattern-element\"></div>\n        <div class=\"pattern-element\"></div>\n        <div class=\"pattern-element\"></div>\n        <div class=\"pattern-element\"></div>\n        <div class=\"pattern-element\"></div>\n        <div class=\"pattern-element\"></div>\n        <div class=\"pattern-element\"></div>\n        <div class=\"pattern-element\"></div>\n        <div class=\"pattern-element\"></div>\n    </div>\n\n    <div class=\"slide\">\n        <div class=\"headline-group\">\n            <h1>{{headline}} <span class=\"highlight\">here.</span></h1>\n        </div>\n\n        <div class=\"number-display\">145K</div>\n        <p class=\"body-text\">{{body}}</p>\n\n        <div class=\"card-container\">\n            <div class=\"card-3d\">\n                <i data-lucide=\"mail\" style=\"width:48px;height:48px\"></i>\n                EMAIL\n            </div>\n            <div class=\"card-3d primary-card\">\n                <i data-lucide=\"bot\" style=\"width:48px;height:48px\"></i>\n                AGENT\n            </div>\n            <div class=\"card-3d secondary-card\">\n                <i data-lucide=\"calendar\" style=\"width:48px;height:48px\"></i>\n                SCHEDULE\n            </div>\n            <div class=\"card-3d\">\n                <i data-lucide=\"code\" style=\"width:48px;height:48px\"></i>\n                CODE\n            </div>\n        </div>\n\n        <div class=\"footer\">\n            <span>Instagram<br>{{brand_name}}</span>\n            <span class=\"swipe-text\">{{cta_text}} <i data-lucide=\"arrow-right\" style=\"width:16px;height:16px\"></i></span>\n        </div>\n    </div>\n\n    <script>\n        lucide.createIcons();\n    </script>\n</body>\n</html>",
