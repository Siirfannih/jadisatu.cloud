    {
      "name": "light-modern",
      "description": "AI-extracted template from reference design",
      "html": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Design Conversion</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <style>\n        /* CSS Variables */\n        :root {\n            --bg: #F8F7F4;\n            --primary: #1A1A1A; /* Main dark text */\n            --secondary: #B0B0B0; /* Dotted lines, light outlines */\n            --accent: #32CD32; /* Green highlight */\n            --text: #1A1A1A;\n            --text-muted: #A0A0A0;\n            --surface: #FFFFFF; /* White circles */\n        }\n\n        /* Base styles */\n        body {\n            margin: 0;\n            padding: 0;\n            width: 1080px;\n            height: 1080px;\n            overflow: hidden;\n            background: var(--bg);\n            font-family: 'Inter', sans-serif;\n            color: var(--text);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .slide {\n            width: 1080px;\n            height: 1080px;\n            padding: 60px 72px;\n            box-sizing: border-box;\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between; /* Distribute space between sections */\n            position: relative; /* For absolute positioning of footer and abstract shapes */\n        }\n\n        /* Typography */\n        .subheadline {\n            font-size: 16px;\n            font-weight: 500;\n            letter-spacing: 1px;\n            text-transform: uppercase;\n            color: var(--text);\n            margin-bottom: 20px;\n        }\n\n        .headline {\n            font-size: 96px;\n            font-weight: 800;\n            line-height: 1.1;\n            margin-bottom: 0; /* Handled by flexbox spacing */\n        }\n\n        .headline .muted {\n            color: var(--text-muted);\n        }\n\n        .body-text {\n            font-size: 32px;\n            font-weight: 400;\n            line-height: 1.4;\n            margin-top: 0; /* Handled by flexbox spacing */\n            max-width: 700px; /* To match line length */\n        }\n\n        .body-text strong {\n            font-weight: 700;\n        }\n\n        /* Diagram */\n        .diagram-container {\n            position: relative;\n            width: 500px; /* Fixed size for diagram area */\n            height: 500px;\n            margin: auto; /* Center the diagram vertically and horizontally within its flex item space */\n            flex-shrink: 0; /* Prevent diagram from shrinking */\n        }\n\n        .center-node {\n            position: absolute;\n            width: 120px;\n            height: 120px;\n            border-radius: 50%;\n            background: var(--text); /* Black background */\n            border: 2px solid var(--accent); /* Green border */\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            color: var(--accent); /* Green text */\n            font-size: 18px;\n            font-weight: 600;\n            text-transform: uppercase;\n            z-index: 2;\n            left: 50%;\n            top: 50%;\n            transform: translate(-50%, -50%); /* Center the node */\n        }\n\n        .outer-node {\n            position: absolute;\n            width: 90px;\n            height: 90px;\n            border-radius: 50%;\n            background: var(--surface); /* White background */\n            border: 2px solid var(--secondary); /* Light grey border */\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            color: var(--text);\n            font-size: 12px;\n            font-weight: 500;\n            text-transform: uppercase;\n            z-index: 1;\n            transform: translate(-50%, -50%); /* Center the node on its calculated position */\n        }\n\n        /* Positioning for outer nodes (angles from positive X-axis, counter-clockwise) */\n        --diagram-radius: 200px; /* Distance from center of diagram to center of outer node */\n\n        .outer-node.node-1 { /* Email, 90 deg */ top: calc(50% - var(--diagram-radius) * 1); left: calc(50% + var(--diagram-radius) * 0); }\n        .outer-node.node-2 { /* Code, 30 deg */ top: calc(50% - var(--diagram-radius) * 0.5); left: calc(50% + var(--diagram-radius) * 0.866); }\n        .outer-node.node-3 { /* Finance, -30 deg */ top: calc(50% - var(--diagram-radius) * -0.5); left: calc(50% + var(--diagram-radius) * 0.866); }\n        .outer-node.node-4 { /* Sched, -90 deg */ top: calc(50% - var(--diagram-radius) * -1); left: calc(50% + var(--diagram-radius) * 0); }\n        .outer-node.node-5 { /* Docs, -150 deg */ top: calc(50% - var(--diagram-radius) * -0.5); left: calc(50% + var(--diagram-radius) * -0.866); }\n        .outer-node.node-6 { /* Comms, 150 deg */ top: calc(50% - var(--diagram-radius) * 0.5); left: calc(50% + var(--diagram-radius) * -0.866); }\n\n        /* Dotted lines */\n        --line-length: 95px; /* Diagram radius - center node radius - outer node radius = 200 - 60 - 45 */\n\n        .line {\n            position: absolute;\n            height: 0; /* No height, just border */\n            width: var(--line-length);\n            border-top: 2px dashed var(--secondary);\n            transform-origin: 0 50%; /* Rotate around the left-center point of the line */\n            left: 50%; /* Position the left-center of the line at the diagram center */\n            top: 50%;\n            z-index: 0;\n        }\n\n        /* Rotations for lines (relative to positive X-axis, then translateX to start at center node edge) */\n        .line-1 { transform: rotate(-90deg) translateX(60px); } /* Top (90 deg from X-axis) */\n        .line-2 { transform: rotate(-30deg) translateX(60px); } /* Top-right (30 deg from X-axis) */\n        .line-3 { transform: rotate(30deg) translateX(60px); } /* Bottom-right (-30 deg from X-axis) */\n        .line-4 { transform: rotate(90deg) translateX(60px); } /* Bottom (-90 deg from X-axis) */\n        .line-5 { transform: rotate(150deg) translateX(60px); } /* Bottom-left (-150 deg from X-axis) */\n        .line-6 { transform: rotate(-150deg) translateX(60px); } /* Top-left (150 deg from X-axis) */\n\n        /* Decorative Abstract Shapes */\n        .abstract-shape {\n            position: absolute;\n            width: 150px; /* Size of the diamond */\n            height: 150px;\n            border: 1px solid var(--text-muted);\n            opacity: 0.1;\n            box-sizing: border-box;\n            border-radius: 10px; /* Slightly rounded corners */\n            z-index: 0;\n        }\n\n        .shape-top-right {\n            top: 80px;\n            right: 80px;\n            transform: rotate(45deg);\n        }\n\n        .shape-bottom-left {\n            bottom: 80px;\n            left: 80px;\n            transform: rotate(-30deg); /* Different rotation */\n        }\n\n        /* Footer */\n        .footer {\n            position: absolute;\n            bottom: 40px;\n            left: 72px;\n            right: 72px;\n            display: flex;\n            justify-content: space-between;\n            font-size: 13px;\n            color: var(--text-muted);\n            font-weight: 500;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"slide\">\n        <div class=\"abstract-shape shape-top-right\"></div>\n        <\n</body>\n</html>",
