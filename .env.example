# JadiSatu Dashboard OS - Environment Variables
# Copy this file to .env.local and fill in your values
# DO NOT COMMIT the actual .env.local file

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database (for direct DB access if needed)
SUPABASE_DB_HOST=db.your-project.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-db-password-here

# Gemini API (for multi-agent system — free at aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter API (for Juru Copilot simple queries — get key at openrouter.ai/keys)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# OpenClaw (optional)
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_TOKEN=your-openclaw-token-here

# Mandala Engine (create mandala-engine/.env with these)
# Uses Gemini for all AI — same GEMINI_API_KEY as above
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here
WA_PROVIDER=fonnte
FONNTE_TOKEN=your-fonnte-token-here
# META_WA_TOKEN=your-meta-wa-token-here
# META_PHONE_ID=your-meta-phone-id-here
GOOGLE_MAPS_API_KEY=your-google-maps-key-here
HUNTER_ENABLED=false
